<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> <!-- 🔥 THIS -->
    <title>AI Bundles | Aquiplex</title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body class="bundle-page">

    <%- include('partials/nav') %>


<h1>✨ AI Bundles</h1>

  <div class="bundle-box">

    <p style="font-size:13px; color:#94a3b8; text-align:center;">
      Enter any goal — like "start freelancing", "grow Instagram", or "learn coding"
    </p>

    <input id="goalInput" placeholder="e.g. Start a YouTube channel..." />
    <button onclick="generateBundle()">Generate Bundle</button>

    <div class="category-buttons">
      <button onclick="quick('Start a YouTube channel')">🎥 YouTuber</button>
      <button onclick="quick('Learn coding fast')">💻 Developer</button>
      <button onclick="quick('Learn video editing')">🎨 Editor</button>
    </div>

    <!-- 🔥 MOVE THIS HERE -->
    <p style="font-size:12px; color:#64748b; text-align:center; margin-top:10px;">
      Aquiplex will generate a step-by-step AI tool bundle to help you achieve it faster 🚀
    </p>
    
  </div>
<div id="result"></div>

      <!-- FOOTER -->    

           <footer class="footer">    
      <p>© <%= new Date().getFullYear() %> AQUIPLEX All rights reserved.</p>    

      </footer>    


<script>
async function generateBundle() {
  const goal = document.getElementById("goalInput").value.trim();

  if (!goal) {
    alert("Please enter a goal");
    return;
  }

  console.log("Sending goal:", goal);

  // 🔄 Loading UI
  document.getElementById("result").innerHTML = `
    <div style="text-align:center; padding:30px;">
      <div class="spinner"></div>
      <p style="margin-top:10px; color:#94a3b8;">Generating your AI bundle...</p>
    </div>
  `;

  try {
    const res = await fetch(window.location.origin + "/generate-bundle", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ goal })
    });

    const data = await res.json();
    console.log("Response:", data);

    if (data.error) {
      document.getElementById("result").innerHTML = `
        ❌ ${data.error}
        <br><br>
        <small>${data.raw || ""}</small>
      `;
      return;
    }

    simulateBuild(data);

  } catch (err) {
    console.error(err);
    document.getElementById("result").innerText = "❌ Failed to connect to server";
  }
}

function quick(text) {
  document.getElementById("goalInput").value = text;
  generateBundle();
}
  function render(data) {
    const result = document.getElementById("result");

    // ❌ ERROR HANDLING
    if (data.error) {
      result.innerHTML = `❌ ${data.error}<br><small>${data.raw || ""}</small>`;
      return;
    }

    let html = "";

    // ================= YOUTUBE =================
    if (data.type === "youtube") {
      html = `
        <h2>📺 ${data.channelName}</h2>
        <p>${data.description}</p>

        <h3>🎯 Niche</h3>
        <p>${data.niche}</p>

        <h3>🎬 Video Ideas</h3>
        <ul>
          ${data.videoIdeas.map(v => `<li>${v}</li>`).join("")}
        </ul>
      `;
    }

    // ================= INSTAGRAM =================
    else if (data.type === "instagram") {
      html = `
        <h2>📸 ${data.username}</h2>
        <p>${data.bio}</p>

        <h3>📸 Content Ideas</h3>
        ${data.ideas.map(i => `<li>${i}</li>`).join("")}
      `;
    }
      // ================= VIDEO EDITING =================
      else if (data.type === "editing") {
        html = `
          <h2>🎬 ${data.title}</h2>

          <h3>🛠 Tools</h3>
          <ul>
            ${data.tools.map(t => `<li>${t}</li>`).join("")}
          </ul>

          <h3>🚀 Steps</h3>
          <ul>
            ${data.steps.map(s => `<li>${s}</li>`).join("")}
          </ul>
        `;
      }

    // ================= WEBSITE =================
    else if (data.type === "website") {
      html = `
        <h2>🌐 ${data.name}</h2>
        <p>${data.tagline}</p>

        <iframe style="width:100%;height:300px;background:#fff"
          srcdoc='${data.html.replace(/'/g, "&apos;")}'></iframe>
      `;
    }

    // ================= STARTUP =================
    else if (data.type === "startup") {
      html = `
        <h2>🚀 ${data.name}</h2>
        <p>${data.idea}</p>

        <iframe style="width:100%;height:300px;background:#fff"
          srcdoc='${data.html.replace(/'/g, "&apos;")}'></iframe>
      `;
    }

    // ================= GENERAL =================
    else if (data.type === "general") {
      html = `
        <h2>${data.title}</h2>
        <p>${data.content}</p>
      `;
    }

    result.innerHTML = html + `
      <br><br>
      <button onclick="executeAction('${data.type}')">
        🚀 Execute
      </button>
    `;
  }
  async function simulateBuild(data) {
    const result = document.getElementById("result");

    // Clear previous result
    result.innerHTML = "";

    function wait(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    // Step 1
    result.innerHTML = "🧠 Understanding your goal...";
    await wait(1000);

    // Step 2
    result.innerHTML = "⚡ Building your project...";
    await wait(1000);

    // Step 3
    result.innerHTML = "🚀 Finalizing...";
    await wait(1000);

    // Final result
    render(data);
  }
  function executeAction(type) {
    if (type === "youtube") {
      window.open("https://studio.youtube.com", "_blank");
    }

    else if (type === "instagram") {
      window.open("https://instagram.com", "_blank");
    }

    else if (type === "editing") {
      window.open("https://www.capcut.com", "_blank");
    }

    else if (type === "website") {
      alert("⚡ Website ready — download feature coming next!");
    }

    else {
      alert("⚡ Action coming soon!");
    }
  }
</script>

  
    <script>
    function openTool(url) {
      window.open(url, "_blank");
    }

      async function shareBundle(data){
        try {
          const res = await fetch("/bundle/save", {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(data)
          });

          const result = await res.json();

          if(result.success){
            const url = window.location.origin + "/bundle/" + result.id;

            navigator.clipboard.writeText(url);
            alert("🔗 Link copied!");
          }

        } catch(err){
          alert("Error sharing bundle");
        }
      }
    </script>


  
</body>
</html>