<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Builder | Aquiplex</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="bundle-page">

<%- include('partials/nav') %>

<h1>🚀 AI Project Builder</h1>

<div class="bundle-box">

  <p style="font-size:13px; color:#94a3b8; text-align:center;">
    Build anything with AI — YouTube, apps, scripts, startups, websites...
  </p>

  <input id="goalInput" placeholder="e.g. Build a YouTube channel..." />
  <button onclick="generateBundle()">Build Project</button>

  <div class="category-buttons">
    <button onclick="quick('Start a YouTube channel')">🎥 YouTuber</button>
    <button onclick="quick('Write a movie script')">🎬 Movie</button>
    <button onclick="quick('Build a website')">🌐 Website</button>
  </div>

</div>

<div id="result"></div>

<footer class="footer">
  <p>© <%= new Date().getFullYear() %> AQUIPLEX All rights reserved.</p>
</footer>

<script>
let userAnswers = null;

// ================= GENERATE =================
async function generateBundle() {
  const goal = document.getElementById("goalInput").value.trim();

  if (!goal) {
    alert("Please enter a goal");
    return;
  }

  document.getElementById("result").innerHTML = `
    <div style="text-align:center; padding:30px;">
      <p>🧠 Thinking...</p>
    </div>
  `;

  try {
    const res = await fetch("/generate-bundle", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        goal,
        answers: userAnswers
      })
    });

    const data = await res.json();
    render(data);

  } catch (err) {
    document.getElementById("result").innerText = "❌ Server error";
  }
}

// ================= QUICK =================
function quick(text) {
  userAnswers = null;
  document.getElementById("goalInput").value = text;
  generateBundle();
}

// ================= RENDER =================
function render(data) {
  const result = document.getElementById("result");

  if (data.error) {
    result.innerHTML = `❌ ${data.error}`;
    return;
  }

  // ================= QUESTIONS =================
  if (data.type === "questions") {
    let html = `<h3>🧠 Answer these to build your project:</h3>`;

    data.questions.forEach((q, i) => {
      html += `
        <p>${q}</p>
        <input id="q${i}" placeholder="Your answer..." /><br><br>
      `;
    });

    html += `<button onclick="submitAnswers()">🚀 Continue</button>`;

    result.innerHTML = html;
    return;
  }

  let html = "";

  // ================= YOUTUBE =================
  if (data.type === "youtube") {
    html = `
      <h2>📺 ${data.channelName}</h2>
      <p>${data.description}</p>

      <h3>🎬 Videos</h3>
      ${(data.videos || []).map(v => `
        <div style="margin-bottom:15px;">
          <b>${v.title}</b><br>
          <button onclick="copyText(\`${v.title}\`)">📋 Copy Title</button>
          <button onclick="copyText(\`${v.script}\`)">📋 Copy Script</button>
          <button onclick="copyText(\`${v.thumbnailText}\`)">📋 Thumbnail</button>
        </div>
      `).join("")}
    `;
  }

  // ================= INSTAGRAM =================
  else if (data.type === "instagram") {
    html = `
      <h2>📸 ${data.username}</h2>
      <p>${data.bio}</p>

      ${(data.posts || []).map(p => `
        <div style="margin-bottom:15px;">
          <b>${p.idea}</b><br>
          <button onclick="copyText(\`${p.caption}\`)">📋 Copy Caption</button>
        </div>
      `).join("")}
    `;
  }

  // ================= EDITING =================
  else if (data.type === "editing") {
    html = `
      <h2>🎬 ${data.title}</h2>

      <h3>🛠 Tools</h3>
      <ul>${(data.tools || []).map(t => `<li>${t}</li>`).join("")}</ul>

      <h3>🚀 Steps</h3>
      <ul>${(data.steps || []).map(s => `<li>${s}</li>`).join("")}</ul>
    `;
  }

  // ================= WEBSITE =================
  else if (data.type === "website") {
    html = `
      <h2>🌐 ${data.name}</h2>
      <p>${data.tagline}</p>

      <button onclick="copyText(\`${data.html}\`)">📋 Copy Code</button>

      <iframe style="width:100%;height:300px;background:#fff"
        srcdoc='${data.html.replace(/'/g, "&apos;")}'></iframe>
    `;
  }

  // ================= GENERAL =================
  else {
    html = `
      <h2>${data.title}</h2>
      <p>${data.description || data.content}</p>
    `;
  }

  result.innerHTML = html + `
    <br><br>
    <button onclick="executeAction('${data.type}')">🚀 Execute</button>
  `;
}

// ================= SUBMIT ANSWERS =================
function submitAnswers() {
  const inputs = document.querySelectorAll("input[id^='q']");
  userAnswers = [];

  inputs.forEach(i => userAnswers.push(i.value));

  generateBundle();
}

// ================= COPY =================
function copyText(text) {
  navigator.clipboard.writeText(text);
  alert("📋 Copied!");
}

// ================= EXECUTE =================
function executeAction(type) {
  if (type === "youtube") {
    window.open("https://studio.youtube.com", "_blank");
  } else if (type === "instagram") {
    window.open("https://instagram.com", "_blank");
  } else if (type === "editing") {
    window.open("https://www.capcut.com", "_blank");
  } else {
    alert("⚡ Action coming soon!");
  }
}
</script>

</body>
</html>