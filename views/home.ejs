<!DOCTYPE html>    
<html lang="en">    

  <head>    

  <meta charset="UTF-8">    
    <meta name="viewport" content="width=device-width, initial-scale=1.0">    
  <title>AQUIPLEX | Discover the Best AI Tools</title>    

  <link rel="stylesheet" href="/css/styles.css">    

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">    

  <!-- ✅ PWA CONFIG (ADD THIS) -->    
  <link rel="manifest" href="/manifest.json">    
  <meta name="theme-color" content="#020617">    

  <!-- ✅ ICONS -->    
  <link rel="icon" href="/logo/logo.png">    
  <link rel="apple-touch-icon" href="/logo/icon-192.png">    

  </head>    

<body>    

  <%- include("partials/nav") %>    


<!-- HERO -->    

    <section class="hero hooked-hero">

      <div class="hero-main">

        <!-- 🔥 HOOK -->
        <h1>
          Stop Searching. <span>Start Using AI.</span>
        </h1>

        <p class="hero-sub">
          Ask once → Get answers from multiple AIs instantly.
        </p>

        <!-- 🧠 MAIN FEATURE (CENTER FOCUS) -->
        <div class="ai-box hero-ai">

          <form id="aiForm">
            <input type="text" id="aiPrompt" placeholder="Ask anything... (e.g. Build a startup idea)" required>
            <button type="submit">⚡ Generate</button>
          </form>

          <div id="aiResults" class="ai-grid">
            <div class="ai-card smart">
              <h3>🧠 Smart</h3>
              <p id="smartText">Waiting...</p>
              <button onclick="copyText('smartText', this)">Copy</button>
            </div>

            <div class="ai-card creative">
              <h3>🎨 Creative</h3>
              <p id="creativeText">Waiting...</p>
              <button onclick="copyText('creativeText', this)">Copy</button>
            </div>

            <div class="ai-card fast">
              <h3>⚡ Fast</h3>
              <p id="fastText">Waiting...</p>
              <button onclick="copyText('fastText', this)">Copy</button>
            </div>
          </div>

        </div>

        <!-- 🎯 TRUST + CTA -->
        <p class="trust-line">🔥 Used by 10,000+ AI explorers</p>

        <div class="hero-cta">
          <a href="/tools" class="btn primary">Explore 100+ Tools</a>
        </div>

      </div>

    </section>


    <section class="section">
      <h2 class="section-title">🔥 Trending AI Tools</h2>
      <p style="text-align:center; opacity:0.7;">
        Discover what everyone is using right now
      </p>
    </section>

    
    <div class="container">    

      <!-- CATEGORY SECTION -->    
      <section class="section">    
        <h2 class="section-title">Explore by Category</h2>    

        <div class="categories">    

          <%    
          const categories = [    
            { name: "Writing AI", icon: "✍️" },    
            { name: "Image AI", icon: "🎨" },    
            { name: "Video AI", icon: "🎬" },    
            { name: "Coding AI", icon: "💻" },    
            { name: "ML AI", icon: "🤖" }    
          ];    

          categories.forEach(function(category){     
          %>    

          <a class="category-card"    
             href="/tools/category/<%= encodeURIComponent(category.name) %>">    

            <div class="category-icon"><%= category.icon %></div>    
            <div class="category-name"><%= category.name %></div>    

          </a>    

          <% }) %>    

        </div>    
      </section>    


      <!-- FEATURED TOOLS -->    
      <section class="section">    

        <h2>Featured Tools</h2>    

        <div class="grid">    

          <% if (tools && tools.length > 0) { %>    

          <% tools.forEach(function(tool){ %>    

          <div class="tool-card">    

            <div class="logo-box">    
              <img src="<%= tool.logo %>" alt="<%= tool.name %>">    
            </div>    

            <a href="/tool/<%= tool._id %>" class="tool-link">    
              <h3><%= tool.name %></h3>    
            </a>    

            <p><%= tool.description %></p>    

            <div class="tool-actions">    

              <a href="/tool/<%= tool._id %>" class="details-btn">    
                View Details    
              </a>    

              <a href="/visit/<%= tool._id %>" target="_blank" class="visit-btn">    
                Visit Tool    
              </a>    

            </div>    

          </div>    

          <% }) %>    

          <% } else { %>    

          <p style="text-align:center;">No tools available yet.</p>    

          <% } %>    

        </div>    

      </section>    

    </div>    

            <!-- INSTALL SECTION -->    
            <section class="section">    
              <h2 class="section-title">📲 How to Install</h2>    

              <div style="max-width:600px; margin:auto; text-align:center; opacity:0.9;">    
                <p>1. Download the APK</p>    
                <p>2. Open the file</p>    
                <p>3. Allow "Install from unknown sources"</p>    
                <p>4. Install & enjoy 🚀</p>    
              </div>    
            </section>    



<!-- FOOTER -->    

     <footer class="footer">    
<p>© <%= new Date().getFullYear() %> AQUIPLEX All rights reserved.</p>    

</footer>    


            <script>    
              document.getElementById("aiForm").addEventListener("submit", async (e) => {    
                e.preventDefault();    

                const prompt = document.getElementById("aiPrompt").value;    

                // Loading states    
                document.getElementById("smartText").innerText = "🧠 Thinking...";    
                document.getElementById("creativeText").innerText = "🎨 Creating...";    
                document.getElementById("fastText").innerText = "⚡ Answering...";    

                try {    
                  const res = await fetch("/multi-generate", {    
                    method: "POST",    
                    headers: {    
                      "Content-Type": "application/json"    
                    },    
                    body: JSON.stringify({ prompt })    
                  });    

                  const data = await res.json();    

                  loadHistory();    

                  data.responses.forEach(r => {    
                    if (r.model.includes("Smart")) {    
                      document.getElementById("smartText").innerText = r.output;    
                    }    

                    if (r.model.includes("Creative")) {    
                      document.getElementById("creativeText").innerText = r.output;    
                    }    

                    if (r.model.includes("Fast")) {    
                      document.getElementById("fastText").innerText = r.output;    
                    }    
                  });    

                } catch (err) {    
                  console.error("FRONTEND ERROR:", err);    

                  document.getElementById("smartText").innerText = "❌ Error";    
                  document.getElementById("creativeText").innerText = "❌ Error";    
                  document.getElementById("fastText").innerText = "❌ Error";    
                }    
              });    
              async function loadHistory() {    
                try {    
                  const res = await fetch("/history");    

                  if (!res.ok) return; // user not logged in    

                  const data = await res.json();    

                  const container = document.getElementById("history");    

                  if (!data.length) {    
                    container.innerHTML = "<p>No history yet</p>";    
                    return;    
                  }    

                  container.innerHTML = data.slice(0, 5).map(item => `    
                    <div class="history-item">    
                      <p class="prompt">${item.prompt}</p>    
                      <button onclick="reusePrompt('${item.prompt.replace(/'/g, "\\'")}')">    
                        Reuse    
                      </button>    
                    </div>    
                  `).join("");    

                } catch (err) {    
                  console.error("History load error", err);    
                }    
              }    

              // load when page opens    
              loadHistory();    

              function reusePrompt(text) {    
                document.getElementById("aiPrompt").value = text;    
                document.getElementById("aiPrompt").focus();    
              }    


                function copyText(id, btn) {    
                  const text = document.getElementById(id).innerText;    

                  navigator.clipboard.writeText(text).then(() => {    
                    btn.innerText = "Copied!";    
                    setTimeout(() => {    
                      btn.innerText = "Copy";    
                    }, 2000);    
                  });    
                }    
              function toggleHistory() {    
                const section = document.getElementById("history-container");    
                const button = document.querySelector(".history-toggle");    

                section.classList.toggle("history-show");    

                if (section.classList.contains("history-show")) {    
                  button.innerText = "❌ Hide Recent Prompts";    
                } else {    
                  button.innerText = "🕘 Show Recent Prompts";    
                }    
              }    
              </script>    

            <script>    
            if ("serviceWorker" in navigator) {    
              navigator.serviceWorker.register("/service-worker.js")    
                .then(() => console.log("SW registered"))    
                .catch(err => console.log("SW failed", err));    
            }    

            </script>    

            <script>    
              if (!/Android/i.test(navigator.userAgent)) {    
                document.querySelector(".apk-section").style.display = "none";    
              }    
            </script>    

  </body>    
</html>