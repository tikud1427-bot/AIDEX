<!DOCTYPE html>
<html>
<head>
  <title>🌊Aqua AI</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <style>
    body {
      background: #020617;
      color: #e2e8f0;
      font-family: 'Segoe UI', sans-serif;
      margin: 0;
    }

    h2 {
      margin-top: 20px;
      color: #38bdf8;
    }

    /* MODE BUTTONS */
    .modes {
      margin: 10px;
    }

    .modes button {
      background: #0f172a;
      color: #e2e8f0;
      border: 1px solid #334155;
      padding: 8px 12px;
      border-radius: 8px;
      margin: 3px;
      cursor: pointer;
      transition: 0.2s;
    }

    .modes button:hover {
      background: #38bdf8;
      color: black;
    }

    #modeLabel {
      margin-bottom: 10px;
      font-size: 14px;
      color: #94a3b8;
    }

    /* CHAT BOX */
    #chat {
      width: 95%;
      max-width: 500px;
      height: 500px;
      overflow-y: auto;
      border: 1px solid #1e293b;
      border-radius: 12px;
      padding: 10px;
      background: #020617;
      box-shadow: 0 0 20px rgba(0,0,0,0.4);
    }

    /* CHAT BUBBLES */
    .msg {
      padding: 10px 14px;
      border-radius: 12px;
      margin: 8px 0;
      max-width: 75%;
      word-wrap: break-word;
    }

    .user {
      background: #38bdf8;
      color: black;
      align-self: flex-end;
      margin-left: auto;
    }

    .bot {
      background: #1e293b;
      color: #22c55e;
      align-self: flex-start;
    }

    /* INPUT AREA */
    .input-area {
      display: flex;
      width: 95%;
      max-width: 500px;
      margin: 10px 0;
    }

    input {
      flex: 1;
      padding: 12px;
      border-radius: 8px;
      border: none;
      outline: none;
      background: #0f172a;
      color: white;
    }

    button.send-btn {
      padding: 12px 16px;
      margin-left: 8px;
      border: none;
      border-radius: 8px;
      background: #22c55e;
      color: black;
      cursor: pointer;
      font-weight: bold;
    }

    button.send-btn:hover {
      background: #16a34a;
    }

    img {
      border-radius: 10px;
      margin-top: 5px;
      max-width: 100%;
    }
    .main {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 20px;
    }
    nav {
      width: 100%;
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    /* ===== NAVBAR FIX ===== */

    .main-header {
      width: 100%;
      background: rgba(2, 6, 23, 0.95);
      border-bottom: 1px solid #1e293b;
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    /* container */
    .header-container {
      max-width: 1200px;
      margin: auto;
      padding: 10px 20px;

      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    /* logo */
    .logo {
      display: flex;
      align-items: center;
      text-decoration: none;
    }

    .logo-img {
      width: 32px;
      height: 32px;
      margin-right: 8px;
    }

    .logo-text {
      color: #38bdf8;
      font-weight: bold;
      font-size: 18px;
    }

    /* nav links */
    .nav-links {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .nav-links a {
      color: #e2e8f0;
      text-decoration: none;
      font-size: 14px;
    }

    .nav-links a:hover {
      color: #38bdf8;
    }

    /* actions */
    .header-actions {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* buttons */
    .btn {
      padding: 6px 12px;
      border-radius: 6px;
      text-decoration: none;
      font-size: 14px;
    }

    .btn.primary {
      background: #22c55e;
      color: black;
    }

    .btn.ghost {
      border: 1px solid #334155;
      color: #e2e8f0;
    }

    /* search */
    .nav-search input {
      padding: 6px 10px;
      border-radius: 6px;
      border: none;
      background: #0f172a;
      color: white;
    }

    /* mobile menu hidden by default */
    .mobile-menu {
      display: none;
      flex-direction: column;
      padding: 10px 20px;
      background: #020617;
    }

    .mobile-menu.active {
      display: flex;
    }

    /* menu button */
    .menu-toggle {
      display: none;
      font-size: 20px;
      cursor: pointer;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {

      .nav-links,
      .nav-search,
      .header-actions {
        display: none;
      }

      .menu-toggle {
        display: block;
      }

    }
    
  </style>
</head>

<body>
  
  <%- include('partials/nav') %>

  <div class="main">

<h2> 🌊 AQUA by Aquiplex</h2>

<div class="modes">
  <button onclick="setMode('chat')">💬 Chat</button>
  <button onclick="setMode('search')">🌐 Search</button>
  <button onclick="setMode('image')">🎨 Image</button>
</div>

<p id="modeLabel">Mode: chat</p>

<div id="chat"></div>

<div class="input-area">
  <input id="msg" placeholder="Ask something..." />
  <button class="send-btn" onclick="send()">Send</button>
  </div>

  </div> <!-- ✅ CLOSE IT HERE -->

  <footer class="footer">
    <p>© <%= new Date().getFullYear() %> AQUIPLEX All rights reserved.</p>
  </footer>

<script>
let history = [];
let mode = "chat";

  function setMode(m) {
    mode = m;
    document.getElementById("modeLabel").innerText = "Mode: " + m;
  }

async function send() {
  const input = document.getElementById("msg");
  const chat = document.getElementById("chat");

  const message = input.value;
  if (!message.trim()) return;

  chat.innerHTML += `<div class="msg user">${message}</div>`;
  input.value = "";

  const loading = document.createElement("div");
  loading.className = "msg bot";
  loading.id = "loading";
  loading.innerText = "Typing...";
  chat.appendChild(loading);

  chat.scrollTop = chat.scrollHeight;

  try {
    const res = await fetch("/chat", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        message,
        history,
        mode
      })
    });

    const data = await res.json(); // ✅ FIXED

    document.getElementById("loading")?.remove();

    if (data.image) {
      chat.innerHTML += `
        <div class="msg bot">
          ${data.reply}
          <br/>
          <img src="${data.image}" />
        </div>`;
    } else {
      chat.innerHTML += `<div class="msg bot">${data.reply}</div>`;
    }

    history.push({ role: "user", content: message });
    history.push({ role: "assistant", content: data.reply });

    chat.scrollTop = chat.scrollHeight;

  } catch (err) {
    document.getElementById("loading")?.remove();
    chat.innerHTML += `<div class="msg bot">⚠️ Error connecting to server</div>`;
  }
}

document.getElementById("msg").addEventListener("keypress", function(e) {
  if (e.key === "Enter") send();
});
</script>

</body>
</html>