<!DOCTYPE html>
<html>
<head>
  <title>Aquiplex Prompt Lab</title>
</head>
<body>

<h1>🧠 Aquiplex Prompt Lab</h1>

<input type="text" id="prompt" placeholder="Ask anything...">
<button onclick="generate()">Generate</button>

<div id="results"></div>

<script>
async function generate() {
  const prompt = document.getElementById("prompt").value;

  const res = await fetch("/generate", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ prompt })
  });

  const data = await res.json();

  document.getElementById("results").innerHTML = `
    <h3>⭐ Smart AI</h3><p>${data.smart}</p>
    <h3>🎨 Creative AI</h3><p>${data.creative}</p>
    <h3>⚡ Fast AI</h3><p>${data.fast}</p>
    <h3>📚 Detailed AI</h3><p>${data.detailed}</p>
  `;
}
</script>

</body>
</html>