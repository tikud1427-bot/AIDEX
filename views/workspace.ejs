<!DOCTYPE html>    
<html lang="en">    

<head>    
<meta charset="UTF-8">    
<meta name="viewport" content="width=device-width, initial-scale=1.0">    
<title>Workspace | AIDEX</title>    

<link rel="stylesheet" href="/css/styles.css">    
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">    
</head>    

<body>    

<%- include('partials/nav') %>    

<main class="container">    

  <!-- HEADER -->    
  <section class="workspace-header">
    <h1>Your Workspace</h1>
    <p>Quick access to your saved AI tools</p>
  </section>    

  <div id="active-tools" class="active-tools-panel"></div>

  

 <!-- GRID -->    
  <div class="workspace-grid" id="workspaceGrid">    

  <% if (workspace && workspace.tools && workspace.tools.length > 0) { %>    

    <% workspace.tools.forEach(function(tool){ %>    

    <div class="workspace-card" id="tool-<%= tool._id %>">    

      <!-- TOP -->    
      <div class="workspace-top">    
        <img     
          src="<%= tool.logo || '/logos/default.png' %>"     
          onerror="this.src='/logos/default.png'"     
          class="workspace-logo"    
          alt="<%= tool.name || 'Tool logo' %>"    
        >    
      </div>    

      <!-- CONTENT -->    
      <div class="workspace-content">    
        <h3><%= tool.name || 'Unnamed Tool' %></h3>

        <% if (tool.description) { %>
          <p class="tool-desc">
            <%= tool.description.substring(0, 80) %>...
          </p>
        <% } else { %>
          <p class="tool-desc muted">No description available</p>
        <% } %>
      </div>    

      <!-- ACTIONS -->    
      <div class="workspace-actions">    

        <button     
          class="launch-btn"   
          onclick="launchTool('<%= tool.name %>', '<%= tool.url || '' %>')"
         >    
          🚀 Launch    
        </button>    

        <button     
          onclick="removeTool('<%= tool._id %>')"     
          class="remove-btn"    
        >    
          ✖ Remove    
        </button>    

      </div>    

    </div>    

    <% }) %>    

  <% } else { %>    

    <div class="empty-workspace" id="emptyState">    
      <h2>No tools saved</h2>    
      <p>Add tools from the tools page to build your workspace</p>    
      <a href="/tools" class="browse-tools-btn">Browse Tools</a>    
    </div>    

  <% } %>    

  </div>    

</main>    


    <!-- 🔥 FAKE BROWSER -->
    <div id="workspace-browser" class="browser hidden">
      <div class="browser-top">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <div class="address-bar" id="browser-url">Loading...</div>
      </div>

      <div class="browser-body">
        <div class="loader">Opening tool...</div>
      </div>
    </div>

    <!-- ✅ SCRIPT STARTS HERE -->
    <script>

    const activeTools = {};
      window.onload = () => {
        updateWorkspaceUI();
      };

    // 🚀 Launch Tool
      function launchTool(name, url){
        if(!url){
          alert("No URL found for this tool");
          return;
        }

        if(!url.startsWith("http")){
          url = "https://" + url;
        }

        const browser = document.getElementById("workspace-browser");
        const urlBar = document.getElementById("browser-url");

        // Show fake browser
        browser.classList.remove("hidden");
        urlBar.innerText = url;

        // Save tool
        activeTools[name] = { url };

        // OPEN TOOL
        window.open(url, "_blank");

        // 🔥 FORCE HIDE AFTER 1s (IMPORTANT)
        setTimeout(() => {
          browser.classList.add("hidden");
          updateWorkspaceUI();
        }, 1000);
      }

      // 🗑️ Remove Tool
      async function removeTool(toolId){
        try {
          const res = await fetch("/workspace/remove/" + toolId, {
            method: "POST"
          });

          if(res.ok){

            const card = document.getElementById("tool-" + toolId);

            if(card){
              // animation
              card.style.transition = "all 0.3s ease";
              card.style.opacity = "0";
              card.style.transform = "scale(0.8)";

              setTimeout(() => {
                card.remove();

                // check empty state
                const grid = document.getElementById("workspaceGrid");
                const remaining = grid.querySelectorAll(".workspace-card");

                if(remaining.length === 0){
                  grid.innerHTML = `
                    <div class="empty-workspace">
                      <h2>No tools saved</h2>
                      <p>Add tools from the tools page</p>
                      <a href="/tools" class="browse-tools-btn">Browse Tools</a>
                    </div>
                  `;
                }

              }, 300);
            }

          } else {
            alert("Failed to remove tool");
          }

        } catch (err){
          console.error(err);
          alert("Error removing tool");
        }
      }
    // 🔥 Render active tools
    function updateWorkspaceUI(){
      const container = document.getElementById("active-tools");
      container.innerHTML = "";

      Object.keys(activeTools).forEach(name => {
        const tool = activeTools[name];

        const div = document.createElement("div");
        div.className = "active-tool";

        div.innerHTML = `
          <span>🧠 ${name}</span>
          <button onclick="resumeTool('${tool.url}')">Resume</button>
        `;

        container.appendChild(div);
      });
    }

    // 🔥 Resume tool
    function resumeTool(url){
      window.open(url, "_blank");
    }

    </script>

    </body>
    </html>