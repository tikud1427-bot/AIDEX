/* ─── TABS ─── */
function switchLeftTab(tab, btn) {
  document.querySelectorAll(".aq-sidebar-tab").forEach(b => b.classList.remove("active"));
  if (btn) btn.classList.add("active");
  else {
    document.querySelectorAll(".aq-sidebar-tab").forEach(b => { if(b.textContent.trim().toLowerCase().startsWith(tab[0])) b.classList.add("active"); });
  }
  document.getElementById("leftProjectList").style.display = tab === "projects" ? "" : "none";
  document.getElementById("leftBundleList").style.display  = tab === "bundles"  ? "" : "none";
}
function switchRightTab(tab, btn) {
  document.querySelectorAll(".aq-right-tab").forEach(b => b.classList.remove("active"));
  document.querySelectorAll(".aq-right-section").forEach(s => s.classList.remove("active"));
  if (btn) btn.classList.add("active");
  else { const t = document.querySelector(`.aq-right-tab[data-tab="${tab}"]`); if(t) t.classList.add("active"); }
  const sec = document.getElementById("rtab-" + tab);
  if (sec) { sec.classList.add("active"); sec.style.opacity="0"; requestAnimationFrame(()=>requestAnimationFrame(()=>sec.style.opacity="1")); }
}

/* ─── INIT ─── */
window.addEventListener("DOMContentLoaded", async () => {
  initBundleSwitcher();
  await loadProjectList();
  try {
    const res  = await fetch("/workspace/state");
    if (!res.ok) throw new Error("state fail");
    const data = await res.json();
    const rawMem = (data.workspace && data.workspace.workspaceMemory) || {};
    STATE.wsMemory  = rawMem instanceof Map ? Object.fromEntries(rawMem) : rawMem;
    STATE.pinnedIds = (data.workspace && data.workspace.pinnedBundleIds) || [];
    if (data.bundles && data.bundles.length) {
      data.bundles.forEach(sb => {
        const idx = STATE.allBundles.findIndex(b => String(b._id) === String(sb._id));
        if (idx !== -1) STATE.allBundles[idx] = sb; else STATE.allBundles.push(sb);
      });
    }
    const recentOutputs = data.workspace && data.workspace.recentOutputs;
    if (recentOutputs && recentOutputs.length) renderOutputFeed(recentOutputs);
    const lastId = data.workspace && data.workspace.lastOpenBundleId;
    if (lastId) {
      const b = (data.bundles || STATE.allBundles).find(x => String(x._id) === String(lastId));
      if (b) { await selectBundle(b); return; }
    }
    const active = STATE.allBundles.find(b => b.status === "active");
    if (active) await selectBundle(active);
  } catch(e) { console.warn("[AQ] init:", e.message); }
});

function focusPrompt() { const i = document.getElementById("topPromptInput"); if(i){i.focus();i.select();} }

/* ─── BUNDLE SWITCHER ─── */
function initBundleSwitcher() {
  const sw = document.getElementById("bundleSwitcher");
  if (!sw) return;
  if (_ejsBundles.length > 0) {
    sw.style.display = "";
    sw.innerHTML = '<option value="">Bundle…</option>' +
      _ejsBundles.map(b => `<option value="${b._id}">${esc(b.title)}</option>`).join("");
    const saved = localStorage.getItem("aq_activeBundle");
    if (saved) sw.value = saved;
    sw.onchange = () => {
      const id = sw.value; const found = STATE.allBundles.find(b => String(b._id) === id);
      if (found) { localStorage.setItem("aq_activeBundle", id); selectBundle(found); }
    };
  }
}

