<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Workspace | Aquiplex</title>
<link rel="stylesheet" href="/css/styles.css"/>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>

<style>
/* ══════════════════════════════════════════════════════════════
   ROOT & RESET
══════════════════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:         #020917;
  --surface:    #060f1e;
  --panel:      #0b1628;
  --border:     #0f2040;
  --border-lit: #1a3a6e;
  --accent:     #00d4ff;
  --accent2:    #7b5fff;
  --accent3:    #ff4fc8;
  --success:    #00e57a;
  --warn:       #ffb520;
  --danger:     #ff4040;
  --text:       #c8d8f0;
  --muted:      #3a5070;
  --bright:     #e8f4ff;
  --font-mono:  'Space Mono', monospace;
  --font-ui:    'Syne', sans-serif;
}

html, body {
  height: 100%;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-ui);
  overflow-x: hidden;
}

/* scanline overlay */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,212,255,0.012) 2px,
    rgba(0,212,255,0.012) 4px
  );
  pointer-events: none;
  z-index: 9999;
}

/* ══════════════════════════════════════════════════════════════
   WORKSPACE SHELL
══════════════════════════════════════════════════════════════ */
.ws-shell {
  display: grid;
  grid-template-columns: 260px 1fr 300px;
  grid-template-rows: 56px 1fr;
  height: 100vh;
  overflow: hidden;
}

/* Top bar */
.ws-topbar {
  grid-column: 1 / -1;
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 0 20px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  position: relative;
  z-index: 100;
}

.ws-logo {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  flex-shrink: 0;
}

.ws-logo span { color: var(--muted); }

.ws-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.78rem;
  color: var(--muted);
  flex: 1;
}

.ws-breadcrumb .sep { color: var(--border-lit); }
.ws-breadcrumb .active { color: var(--bright); font-weight: 600; }

.ws-status-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: var(--font-mono);
  font-size: 0.68rem;
}

.ws-pulse {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 8px var(--success);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.ws-status-text { color: var(--success); }

/* ══════════════════════════════════════════════════════════════
   LEFT PANEL — NAV
══════════════════════════════════════════════════════════════ */
.ws-left {
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.panel-hdr {
  padding: 14px 16px 10px;
  font-family: var(--font-mono);
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.panel-hdr .badge {
  background: var(--border-lit);
  color: var(--accent);
  padding: 2px 7px;
  border-radius: 20px;
  font-size: 0.6rem;
}

/* Nav tabs */
.ws-nav {
  display: flex;
  border-bottom: 1px solid var(--border);
}

.ws-nav-btn {
  flex: 1;
  padding: 10px 4px;
  background: none;
  border: none;
  color: var(--muted);
  font-family: var(--font-mono);
  font-size: 0.6rem;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  transition: all 0.15s;
  border-bottom: 2px solid transparent;
}

.ws-nav-btn.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
  background: rgba(0,212,255,0.04);
}

.ws-nav-btn:hover:not(.active) {
  color: var(--text);
  background: rgba(255,255,255,0.03);
}

/* Scrollable list area */
.ws-list {
  flex: 1;
  overflow-y: auto;
  padding: 8px;
}

.ws-list::-webkit-scrollbar { width: 3px; }
.ws-list::-webkit-scrollbar-thumb { background: var(--border-lit); border-radius: 2px; }

/* Bundle row */
.bundle-row {
  padding: 10px 10px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.15s;
  border: 1px solid transparent;
  margin-bottom: 3px;
  position: relative;
}

.bundle-row:hover { background: var(--panel); border-color: var(--border); }
.bundle-row.selected { background: var(--panel); border-color: var(--border-lit); }
.bundle-row.selected::before {
  content: '';
  position: absolute;
  left: 0; top: 4px; bottom: 4px;
  width: 2px;
  background: var(--accent);
  border-radius: 2px;
}

.bundle-row-title {
  font-size: 0.82rem;
  color: var(--bright);
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 5px;
}

.bundle-row-meta {
  display: flex;
  align-items: center;
  gap: 8px;
}

.bundle-row-bar {
  flex: 1;
  height: 3px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
}

.bundle-row-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  border-radius: 2px;
  transition: width 0.4s ease;
}

.bundle-row-pct {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--muted);
  flex-shrink: 0;
}

.bundle-status-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-active   { background: var(--success); box-shadow: 0 0 5px var(--success); animation: pulse 2s infinite; }
.dot-paused   { background: var(--warn); }
.dot-completed{ background: var(--accent2); }
.dot-draft    { background: var(--muted); }

/* Tool row */
.tool-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.15s;
  margin-bottom: 2px;
}

.tool-row:hover { background: var(--panel); }

.tool-logo {
  width: 28px; height: 28px;
  border-radius: 6px;
  object-fit: contain;
  background: var(--border);
  flex-shrink: 0;
}

.tool-row-name {
  font-size: 0.8rem;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.tool-launch-btn {
  background: none;
  border: 1px solid var(--border-lit);
  color: var(--accent);
  padding: 3px 8px;
  border-radius: 5px;
  font-size: 0.65rem;
  font-family: var(--font-mono);
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.15s;
}

.tool-row:hover .tool-launch-btn { opacity: 1; }

.empty-state {
  padding: 24px 10px;
  text-align: center;
  color: var(--muted);
  font-size: 0.78rem;
}

.empty-state a {
  color: var(--accent);
  text-decoration: none;
  font-family: var(--font-mono);
  font-size: 0.72rem;
}

/* ══════════════════════════════════════════════════════════════
   CENTER PANEL — EXECUTION
══════════════════════════════════════════════════════════════ */
.ws-center {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg);
}

/* Welcome screen */
.ws-welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 40px;
  text-align: center;
}

.ws-welcome-icon {
  font-size: 3rem;
  margin-bottom: 20px;
  opacity: 0.6;
}

.ws-welcome h2 {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--bright);
  margin-bottom: 10px;
}

.ws-welcome p {
  color: var(--muted);
  font-size: 0.88rem;
  max-width: 340px;
  line-height: 1.6;
}

/* Execution view */
.ws-exec {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
}

/* Bundle header bar */
.exec-header {
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--surface);
  flex-shrink: 0;
}

.exec-title-block { flex: 1; min-width: 0; }

.exec-title {
  font-size: 1.05rem;
  font-weight: 800;
  color: var(--bright);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.exec-goal {
  font-size: 0.75rem;
  color: var(--muted);
  margin-top: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.exec-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

.exec-btn {
  padding: 7px 14px;
  border-radius: 7px;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 700;
  border: 1px solid var(--border-lit);
  cursor: pointer;
  transition: all 0.15s;
  letter-spacing: 0.05em;
}

.exec-btn-run {
  background: var(--accent);
  color: #000;
  border-color: var(--accent);
}

.exec-btn-run:hover { opacity: 0.85; transform: translateY(-1px); }

.exec-btn-pause {
  background: transparent;
  color: var(--warn);
  border-color: var(--warn);
}

.exec-btn-pause:hover { background: rgba(255,181,32,0.08); }

.exec-btn-secondary {
  background: transparent;
  color: var(--text);
}

.exec-btn-secondary:hover { background: var(--panel); }

/* Progress timeline */
.exec-timeline {
  padding: 12px 20px;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  display: flex;
  align-items: center;
  gap: 0;
  overflow-x: auto;
  flex-shrink: 0;
}

.exec-timeline::-webkit-scrollbar { height: 2px; }
.exec-timeline::-webkit-scrollbar-thumb { background: var(--border-lit); }

.tl-step {
  display: flex;
  align-items: center;
  cursor: pointer;
  flex-shrink: 0;
}

.tl-dot {
  width: 28px; height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 700;
  border: 2px solid var(--border-lit);
  background: var(--panel);
  color: var(--muted);
  transition: all 0.2s;
  position: relative;
}

.tl-dot.done {
  background: rgba(0,229,122,0.12);
  border-color: var(--success);
  color: var(--success);
}

.tl-dot.running {
  background: rgba(0,212,255,0.12);
  border-color: var(--accent);
  color: var(--accent);
  box-shadow: 0 0 10px rgba(0,212,255,0.3);
  animation: pulse 1.5s infinite;
}

.tl-dot.selected-step {
  transform: scale(1.15);
  box-shadow: 0 0 12px rgba(123,95,255,0.5);
  border-color: var(--accent2);
  color: var(--accent2);
}

.tl-dot.failed {
  background: rgba(255,64,64,0.12);
  border-color: var(--danger);
  color: var(--danger);
}

.tl-connector {
  height: 2px;
  width: 24px;
  background: var(--border);
  flex-shrink: 0;
}

.tl-connector.done { background: var(--success); opacity: 0.4; }

/* Step cards area */
.exec-steps {
  flex: 1;
  overflow-y: auto;
  padding: 16px 20px;
}

.exec-steps::-webkit-scrollbar { width: 3px; }
.exec-steps::-webkit-scrollbar-thumb { background: var(--border-lit); }

/* Individual step card */
.step-card {
  border: 1px solid var(--border);
  border-radius: 12px;
  margin-bottom: 10px;
  background: var(--surface);
  overflow: hidden;
  transition: border-color 0.2s;
}

.step-card.active-card { border-color: var(--border-lit); }
.step-card.running-card { border-color: var(--accent); box-shadow: 0 0 16px rgba(0,212,255,0.08); }
.step-card.done-card { border-color: rgba(0,229,122,0.2); }

.step-card-hdr {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  cursor: pointer;
  user-select: none;
}

.step-num {
  width: 30px; height: 30px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 700;
  background: var(--panel);
  border: 1px solid var(--border-lit);
  color: var(--muted);
  flex-shrink: 0;
}

.step-num.done { background: rgba(0,229,122,0.1); border-color: var(--success); color: var(--success); }
.step-num.running { background: rgba(0,212,255,0.1); border-color: var(--accent); color: var(--accent); animation: pulse 1.5s infinite; }

.step-card-info { flex: 1; min-width: 0; }

.step-card-title {
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--bright);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.step-card-desc {
  font-size: 0.74rem;
  color: var(--muted);
  margin-top: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.step-badge {
  padding: 3px 9px;
  border-radius: 20px;
  font-family: var(--font-mono);
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  flex-shrink: 0;
}

.badge-pending  { background: var(--panel); color: var(--muted); border: 1px solid var(--border); }
.badge-running  { background: rgba(0,212,255,0.1); color: var(--accent); border: 1px solid rgba(0,212,255,0.25); }
.badge-done     { background: rgba(0,229,122,0.1); color: var(--success); border: 1px solid rgba(0,229,122,0.25); }
.badge-failed   { background: rgba(255,64,64,0.1); color: var(--danger); border: 1px solid rgba(255,64,64,0.25); }

.step-toggle {
  color: var(--muted);
  font-size: 0.7rem;
  flex-shrink: 0;
  transition: transform 0.2s;
}

.step-toggle.open { transform: rotate(180deg); }

/* Expand body */
.step-card-body {
  border-top: 1px solid var(--border);
  padding: 14px 16px;
  display: none;
}

.step-card-body.open { display: block; }

/* Step tools */
.step-tools {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 12px;
}

.step-tool-chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 4px 10px;
  background: var(--panel);
  border: 1px solid var(--border-lit);
  border-radius: 6px;
  font-size: 0.72rem;
  color: var(--accent);
  text-decoration: none;
  transition: all 0.15s;
}

.step-tool-chip:hover { background: rgba(0,212,255,0.05); border-color: var(--accent); }

/* Output block */
.step-output-block {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}

.step-output-label {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 8px;
}

.step-output-content {
  font-size: 0.8rem;
  color: var(--text);
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
  max-height: 240px;
  overflow-y: auto;
}

.step-output-content::-webkit-scrollbar { width: 3px; }
.step-output-content::-webkit-scrollbar-thumb { background: var(--border-lit); }

/* Insights */
.step-insights {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 12px;
}

.insight-chip {
  padding: 3px 9px;
  background: rgba(123,95,255,0.08);
  border: 1px solid rgba(123,95,255,0.2);
  border-radius: 20px;
  font-size: 0.7rem;
  color: var(--accent2);
}

/* Step actions */
.step-card-actions {
  display: flex;
  gap: 8px;
}

.step-action-btn {
  padding: 6px 12px;
  border-radius: 6px;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 700;
  border: 1px solid;
  cursor: pointer;
  transition: all 0.15s;
  letter-spacing: 0.04em;
}

.btn-mark-done {
  background: rgba(0,229,122,0.08);
  color: var(--success);
  border-color: rgba(0,229,122,0.25);
}

.btn-mark-done:hover { background: rgba(0,229,122,0.15); }

.btn-rerun {
  background: rgba(0,212,255,0.06);
  color: var(--accent);
  border-color: rgba(0,212,255,0.2);
}

.btn-rerun:hover { background: rgba(0,212,255,0.12); }

/* Streaming text */
.streaming-line {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--accent);
  padding: 10px 12px;
  background: rgba(0,212,255,0.04);
  border-radius: 6px;
  min-height: 36px;
  border-left: 2px solid var(--accent);
}

.streaming-cursor {
  display: inline-block;
  width: 6px; height: 12px;
  background: var(--accent);
  margin-left: 2px;
  animation: blink 1s step-end infinite;
  vertical-align: middle;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ══════════════════════════════════════════════════════════════
   RIGHT PANEL — OUTPUT + MEMORY
══════════════════════════════════════════════════════════════ */
.ws-right {
  background: var(--surface);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.right-tabs {
  display: flex;
  border-bottom: 1px solid var(--border);
}

.right-tab-btn {
  flex: 1;
  padding: 10px 4px;
  background: none;
  border: none;
  color: var(--muted);
  font-family: var(--font-mono);
  font-size: 0.58rem;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  transition: all 0.15s;
  border-bottom: 2px solid transparent;
}

.right-tab-btn.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
  background: rgba(0,212,255,0.04);
}

.right-tab-btn:hover:not(.active) { color: var(--text); }

.right-panel-body {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
}

.right-panel-body::-webkit-scrollbar { width: 3px; }
.right-panel-body::-webkit-scrollbar-thumb { background: var(--border-lit); }

.right-section { display: none; }
.right-section.active { display: block; }

/* Output feed */
.output-feed-item {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 8px;
  cursor: pointer;
  transition: border-color 0.15s;
}

.output-feed-item:hover { border-color: var(--border-lit); }

.output-feed-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
}

.output-feed-step {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.output-feed-bundle {
  font-size: 0.62rem;
  color: var(--muted);
  max-width: 120px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.output-feed-preview {
  font-size: 0.76rem;
  color: var(--text);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Memory panel */
.memory-section-hdr {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 8px 0 6px;
  margin-bottom: 6px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.memory-section-hdr span { color: var(--accent); font-size: 0.58rem; }

.memory-kv {
  margin-bottom: 8px;
  padding: 8px 10px;
  background: var(--panel);
  border-radius: 6px;
  border-left: 2px solid var(--accent2);
}

.mem-k {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  color: var(--accent2);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 2px;
}

.mem-v {
  font-size: 0.78rem;
  color: var(--text);
  line-height: 1.5;
  word-break: break-word;
}

/* Context summary */
.context-box {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
  font-size: 0.76rem;
  color: var(--text);
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}

/* Insights right panel */
.insight-list-item {
  display: flex;
  gap: 8px;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.78rem;
  color: var(--text);
  line-height: 1.5;
}

.insight-list-item::before {
  content: '◆';
  color: var(--accent);
  font-size: 0.6rem;
  flex-shrink: 0;
  margin-top: 3px;
}

/* ══════════════════════════════════════════════════════════════
   STATS ROW
══════════════════════════════════════════════════════════════ */
.exec-stats {
  display: flex;
  gap: 12px;
  padding: 10px 20px;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  flex-shrink: 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.stat-val {
  font-family: var(--font-mono);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--bright);
}

.stat-val.accent { color: var(--accent); }
.stat-val.success { color: var(--success); }
.stat-val.warn { color: var(--warn); }

.stat-lbl {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

/* ══════════════════════════════════════════════════════════════
   TOAST
══════════════════════════════════════════════════════════════ */
.toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  padding: 10px 18px;
  border-radius: 8px;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  z-index: 9999;
  animation: toastIn 0.2s ease;
}

@keyframes toastIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.toast-success { background: rgba(0,229,122,0.12); border: 1px solid var(--success); color: var(--success); }
.toast-info    { background: rgba(0,212,255,0.12); border: 1px solid var(--accent);  color: var(--accent);  }
.toast-error   { background: rgba(255,64,64,0.12); border: 1px solid var(--danger);  color: var(--danger);  }

/* ══════════════════════════════════════════════════════════════
   SPINNER
══════════════════════════════════════════════════════════════ */
.spin {
  width: 14px; height: 14px;
  border: 2px solid var(--border-lit);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
  display: inline-block;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ══════════════════════════════════════════════════════════════
   OVERALL PROGRESS BAR
══════════════════════════════════════════════════════════════ */
.exec-progress-bar-wrap {
  padding: 0 20px 0;
  background: var(--surface);
  flex-shrink: 0;
}

.exec-progress-bar-track {
  height: 3px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 10px;
}

.exec-progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--accent2), var(--accent3));
  border-radius: 2px;
  transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
}

/* ══════════════════════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════════════════════ */
@media (max-width: 1000px) {
  .ws-shell {
    grid-template-columns: 200px 1fr;
    grid-template-rows: 56px 1fr;
  }
  .ws-right { display: none; }
}

@media (max-width: 680px) {
  .ws-shell {
    grid-template-columns: 1fr;
    grid-template-rows: 56px auto 1fr;
  }
  .ws-left {
    grid-row: 2;
    max-height: 220px;
    border-right: none;
    border-bottom: 1px solid var(--border);
  }
  .ws-center { grid-row: 3; }
}
</style>
</head>

<body>
<%- include('partials/nav') %>

<!-- ════════════════════════════════════════════════════════════
     WORKSPACE SHELL
════════════════════════════════════════════════════════════ -->
<div class="ws-shell">

  <!-- ── TOP BAR ── -->
  <div class="ws-topbar">
    <div class="ws-logo">AQUI<span>PLEX</span> // WORKSPACE</div>

    <div class="ws-breadcrumb">
      <span>Workspace</span>
      <span class="sep">›</span>
      <span class="active" id="topBreadcrumb">Overview</span>
    </div>

    <div class="ws-status-bar">
      <div class="ws-pulse"></div>
      <span class="ws-status-text" id="topStatusText">SYSTEM ONLINE</span>
    </div>
  </div>

  <!-- ════════════════════════════════
       LEFT PANEL
  ════════════════════════════════ -->
  <div class="ws-left">
    <div class="ws-nav">
      <button class="ws-nav-btn active" onclick="switchLeftTab('bundles', this)">BUNDLES</button>
      <button class="ws-nav-btn" onclick="switchLeftTab('tools', this)">TOOLS</button>
    </div>

    <!-- BUNDLES LIST -->
    <div class="ws-list" id="leftBundleList">
      <% if (bundles && bundles.length > 0) { %>
        <% bundles.forEach(function(b) {
          const completed = (b.progress || []).filter(p => p.status === 'completed').length;
          const total     = (b.steps || []).length;
          const pct       = total > 0 ? Math.round((completed / total) * 100) : 0;
          const dotCls    = b.status === 'active' ? 'dot-active'
                          : b.status === 'paused' ? 'dot-paused'
                          : b.status === 'completed' ? 'dot-completed'
                          : 'dot-draft';
        %>
        <div class="bundle-row" id="brow-<%= b._id %>"
             onclick="selectBundle(<%- JSON.stringify(b).replace(/</g,'\\u003c') %>)">
          <div class="bundle-row-title"><%= b.title %></div>
          <div class="bundle-row-meta">
            <div class="bundle-status-dot <%= dotCls %>"></div>
            <div class="bundle-row-bar">
              <div class="bundle-row-fill" style="width:<%= pct %>%"></div>
            </div>
            <div class="bundle-row-pct"><%= pct %>%</div>
          </div>
        </div>
        <% }) %>
      <% } else { %>
        <div class="empty-state">
          No bundles yet.<br/>
          <a href="/bundles">Create one →</a>
        </div>
      <% } %>
    </div>

    <!-- TOOLS LIST -->
    <div class="ws-list" id="leftToolList" style="display:none;">
      <% if (workspace && workspace.tools && workspace.tools.length > 0) { %>
        <% workspace.tools.forEach(function(tool) { %>
        <div class="tool-row">
          <img src="<%= tool.logo || '/logos/default.png' %>"
               onerror="this.src='/logos/default.png'"
               class="tool-logo" alt=""/>
          <span class="tool-row-name"><%= tool.name %></span>
          <button class="tool-launch-btn"
                  onclick="event.stopPropagation(); launchTool('<%= tool.url || '' %>')">
            OPEN
          </button>
        </div>
        <% }) %>
      <% } else { %>
        <div class="empty-state">
          No tools saved.<br/>
          <a href="/tools">Browse tools →</a>
        </div>
      <% } %>
    </div>
  </div>

  <!-- ════════════════════════════════
       CENTER PANEL
  ════════════════════════════════ -->
  <div class="ws-center">

    <!-- Welcome screen (shown when no bundle selected) -->
    <div class="ws-welcome" id="wsWelcome">
      <div class="ws-welcome-icon">⚡</div>
      <h2>Execution Control Center</h2>
      <p>Select a bundle from the left panel to view its execution state, step timeline, outputs, and memory.</p>
    </div>

    <!-- Execution view (shown when bundle selected) -->
    <div class="ws-exec" id="wsExec" style="display:none;">

      <!-- Bundle header -->
      <div class="exec-header">
        <div class="exec-title-block">
          <div class="exec-title" id="execTitle">—</div>
          <div class="exec-goal" id="execGoal">—</div>
        </div>
        <div class="exec-actions">
          <button class="exec-btn exec-btn-run" id="btnRun" onclick="runCurrentBundle()">
            ▶ RUN
          </button>
          <button class="exec-btn exec-btn-pause" id="btnPause" onclick="pauseCurrentBundle()" style="display:none;">
            ⏸ PAUSE
          </button>
          <button class="exec-btn exec-btn-secondary" onclick="resumeCurrentBundle()" id="btnResume" style="display:none;">
            ↺ RESUME
          </button>
          <button class="exec-btn exec-btn-secondary" onclick="pinCurrentBundle()" id="btnPin">
            ☆ PIN
          </button>
        </div>
      </div>

      <!-- Stats row -->
      <div class="exec-stats">
        <div class="stat-item">
          <div class="stat-val accent" id="statSteps">—</div>
          <div class="stat-lbl">STEPS</div>
        </div>
        <div class="stat-item">
          <div class="stat-val success" id="statDone">—</div>
          <div class="stat-lbl">DONE</div>
        </div>
        <div class="stat-item">
          <div class="stat-val" id="statPct">—</div>
          <div class="stat-lbl">COMPLETE</div>
        </div>
        <div class="stat-item">
          <div class="stat-val warn" id="statStatus">—</div>
          <div class="stat-lbl">STATUS</div>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="exec-progress-bar-wrap">
        <div class="exec-progress-bar-track">
          <div class="exec-progress-bar-fill" id="mainProgressFill" style="width:0%"></div>
        </div>
      </div>

      <!-- Timeline strip -->
      <div class="exec-timeline" id="execTimeline"></div>

      <!-- Step cards -->
      <div class="exec-steps" id="execSteps"></div>

    </div>
  </div>

  <!-- ════════════════════════════════
       RIGHT PANEL
  ════════════════════════════════ -->
  <div class="ws-right">
    <div class="right-tabs">
      <button class="right-tab-btn active" onclick="switchRightTab('outputs', this)">OUTPUTS</button>
      <button class="right-tab-btn" onclick="switchRightTab('memory', this)">MEMORY</button>
      <button class="right-tab-btn" onclick="switchRightTab('insights', this)">INSIGHTS</button>
    </div>

    <div class="right-panel-body">

      <!-- OUTPUTS -->
      <div class="right-section active" id="rtab-outputs">
        <div id="outputFeed">
          <div class="empty-state" style="padding:30px 0;">
            Run a bundle step to see outputs here.
          </div>
        </div>
      </div>

      <!-- MEMORY -->
      <div class="right-section" id="rtab-memory">
        <div class="memory-section-hdr">
          Bundle Memory <span id="memBundleCount">0 keys</span>
        </div>
        <div id="memBundleEntries"></div>

        <div class="memory-section-hdr" style="margin-top:16px;">
          Context Summary
        </div>
        <div class="context-box" id="memContextBox" style="display:none;"></div>
        <div class="empty-state" id="memContextEmpty">No context summary yet.</div>

        <div class="memory-section-hdr" style="margin-top:16px;">
          Workspace Memory <span id="memWsCount">0 keys</span>
        </div>
        <div id="memWsEntries"></div>
      </div>

      <!-- INSIGHTS -->
      <div class="right-section" id="rtab-insights">
        <div id="insightList">
          <div class="empty-state" style="padding:30px 0;">
            Key insights extracted from step outputs will appear here.
          </div>
        </div>
      </div>

    </div>
  </div>

</div><!-- /.ws-shell -->

<%- include("partials/footer") %>

<!-- ════════════════════════════════════════════════════════════
     JAVASCRIPT
════════════════════════════════════════════════════════════ -->
<script>
// ═══════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════
const STATE = {
  bundle:        null,    // currently selected bundle object
  wsMemory:      {},      // workspace-level memory
  pinnedIds:     [],
  selectedStep:  null,
};

// ═══════════════════════════════════════════
// INIT — hydrate from server
// ═══════════════════════════════════════════
window.addEventListener("DOMContentLoaded", async () => {
  try {
    const res  = await fetch("/workspace/state");
    const data = await res.json();
    STATE.wsMemory  = data.workspace.workspaceMemory || {};
    STATE.pinnedIds = data.workspace.pinnedBundleIds  || [];

    renderWsMemory();

    // Recent outputs
    if (data.workspace.recentOutputs && data.workspace.recentOutputs.length) {
      renderOutputFeed(data.workspace.recentOutputs);
    }

    // Auto-open last bundle
    const lastId = data.workspace.lastOpenBundleId;
    if (lastId) {
      const b = (data.bundles || []).find(x => x._id === lastId || x._id.toString() === lastId);
      if (b) { selectBundle(b); return; }
    }

    // Auto-open first active bundle
    const active = (data.bundles || []).find(b => b.status === "active");
    if (active) selectBundle(active);
  } catch (e) {
    console.warn("Workspace state load failed", e);
  }
});

// ═══════════════════════════════════════════
// LEFT TAB SWITCH
// ═══════════════════════════════════════════
function switchLeftTab(tab, btn) {
  document.querySelectorAll(".ws-nav-btn").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
  document.getElementById("leftBundleList").style.display = tab === "bundles" ? "" : "none";
  document.getElementById("leftToolList").style.display   = tab === "tools"   ? "" : "none";
}

// ═══════════════════════════════════════════
// RIGHT TAB SWITCH
// ═══════════════════════════════════════════
function switchRightTab(tab, btn) {
  document.querySelectorAll(".right-tab-btn").forEach(b => b.classList.remove("active"));
  document.querySelectorAll(".right-section").forEach(s => s.classList.remove("active"));
  btn.classList.add("active");
  document.getElementById("rtab-" + tab).classList.add("active");
}

// ═══════════════════════════════════════════
// SELECT BUNDLE
// ═══════════════════════════════════════════
async function selectBundle(bundle) {
  // Highlight row
  document.querySelectorAll(".bundle-row").forEach(r => r.classList.remove("selected"));
  const row = document.getElementById("brow-" + (bundle._id || bundle.id));
  if (row) row.classList.add("selected");

  // Fetch fresh state
  try {
    const res  = await fetch("/workspace/bundle/" + (bundle._id || bundle.id));
    const data = await res.json();
    if (data.bundle) bundle = data.bundle;
  } catch(_) {}

  STATE.bundle       = bundle;
  STATE.selectedStep = null;

  // Show exec panel
  document.getElementById("wsWelcome").style.display = "none";
  document.getElementById("wsExec").style.display    = "flex";

  renderExecPanel(bundle);
  renderMemoryPanel(bundle);
  renderInsightPanel(bundle);
  updateBreadcrumb(bundle.title);
  updatePinBtn(bundle._id || bundle.id);
}

// ═══════════════════════════════════════════
// RENDER EXEC PANEL
// ═══════════════════════════════════════════
function renderExecPanel(b) {
  const steps    = b.steps    || [];
  const progress = b.progress || [];
  const outputs  = b.outputs  || [];

  const done  = progress.filter(p => p.status === "completed").length;
  const total = steps.length;
  const pct   = total ? Math.round((done / total) * 100) : 0;

  // Header
  document.getElementById("execTitle").textContent = b.title || "Untitled";
  document.getElementById("execGoal").textContent  = b.goal  || "";

  // Stats
  document.getElementById("statSteps").textContent  = total;
  document.getElementById("statDone").textContent   = done;
  document.getElementById("statPct").textContent    = pct + "%";
  document.getElementById("statStatus").textContent = (b.status || "draft").toUpperCase();

  // Progress bar
  document.getElementById("mainProgressFill").style.width = pct + "%";

  // Run/pause/resume buttons
  const btnRun    = document.getElementById("btnRun");
  const btnPause  = document.getElementById("btnPause");
  const btnResume = document.getElementById("btnResume");

  if (b.status === "active") {
    btnRun.style.display    = "none";
    btnPause.style.display  = "";
    btnResume.style.display = "none";
  } else if (b.status === "paused") {
    btnRun.style.display    = "none";
    btnPause.style.display  = "none";
    btnResume.style.display = "";
  } else if (b.status === "completed") {
    btnRun.style.display    = "none";
    btnPause.style.display  = "none";
    btnResume.style.display = "none";
  } else {
    btnRun.style.display    = "";
    btnPause.style.display  = "none";
    btnResume.style.display = "none";
  }

  // Timeline
  renderTimeline(steps, progress, b.currentStep || 0);

  // Step cards
  renderStepCards(steps, progress, outputs, b.currentStep || 0);
}

// ═══════════════════════════════════════════
// TIMELINE
// ═══════════════════════════════════════════
function renderTimeline(steps, progress, currentStep) {
  const tl = document.getElementById("execTimeline");
  if (!steps.length) { tl.innerHTML = ""; return; }

  tl.innerHTML = steps.map((step, i) => {
    const prog   = progress.find(p => p.step === i);
    const status = prog ? prog.status : "pending";
    const dotCls = status === "completed"   ? "done"
                 : status === "in-progress" ? "running"
                 : i === STATE.selectedStep  ? "selected-step"
                 : "";
    const icon = status === "completed" ? "✓"
               : status === "in-progress" ? "…"
               : (i + 1);
    const connector = i < steps.length - 1
      ? `<div class="tl-connector ${status === 'completed' ? 'done' : ''}"></div>`
      : "";
    return `
      <div class="tl-step" title="${esc(step.title || 'Step ' + (i+1))}" onclick="jumpToStep(${i})">
        <div class="tl-dot ${dotCls}">${icon}</div>
      </div>${connector}
    `;
  }).join("");
}

// ═══════════════════════════════════════════
// STEP CARDS
// ═══════════════════════════════════════════
function renderStepCards(steps, progress, outputs, currentStep) {
  const container = document.getElementById("execSteps");
  if (!steps.length) {
    container.innerHTML = `<div class="empty-state">No steps defined.</div>`;
    return;
  }

  container.innerHTML = steps.map((step, i) => {
    const prog   = progress.find(p => p.step === i);
    const status = prog ? prog.status : "pending";
    const output = outputs.find(o => o.stepIndex === i);

    const cardCls  = status === "in-progress" ? "running-card"
                   : status === "completed"   ? "done-card"
                   : i === currentStep        ? "active-card"
                   : "";
    const badgeCls = status === "completed"   ? "badge-done"
                   : status === "in-progress" ? "badge-running"
                   : status === "failed"      ? "badge-failed"
                   : "badge-pending";
    const badgeTxt = status === "completed"   ? "DONE"
                   : status === "in-progress" ? "RUNNING"
                   : status === "failed"      ? "FAILED"
                   : "PENDING";
    const numCls   = status === "completed"   ? "done"
                   : status === "in-progress" ? "running"
                   : "";
    const numIcon  = status === "completed" ? "✓" : (i + 1);

    // Tools chips
    const toolsHtml = (step.tools && step.tools.length)
      ? `<div class="step-tools">${step.tools.map(t =>
          `<a class="step-tool-chip" href="${esc(t.url||'#')}" target="_blank">🔗 ${esc(t.name||'Tool')}</a>`
        ).join("")}</div>`
      : "";

    // Output block
    let outputHtml = "";
    if (output && output.content) {
      const insights = (output.keyInsights || []).slice(0, 4).map(k =>
        `<span class="insight-chip">${esc(k)}</span>`
      ).join("");
      outputHtml = `
        <div class="step-output-block">
          <div class="step-output-label">⚡ OUTPUT</div>
          <div class="step-output-content">${formatOutput(output.content)}</div>
        </div>
        ${insights ? `<div class="step-insights">${insights}</div>` : ""}
      `;
    }

    // Action buttons
    const actionHtml = status !== "completed"
      ? `<button class="step-action-btn btn-mark-done"
           onclick="event.stopPropagation(); markStepDone(${i})">
           ✅ Mark Done
         </button>`
      : `<button class="step-action-btn btn-rerun"
           onclick="event.stopPropagation(); rerunStep(${i})">
           ↺ Re-run
         </button>`;

    const isOpen = i === currentStep || i === STATE.selectedStep;

    return `
      <div class="step-card ${cardCls}" id="scard-${i}">
        <div class="step-card-hdr" onclick="toggleCard(${i})">
          <div class="step-num ${numCls}">${numIcon}</div>
          <div class="step-card-info">
            <div class="step-card-title">${esc(step.title || 'Step ' + (i+1))}</div>
            <div class="step-card-desc">${esc(step.description || '')}</div>
          </div>
          <span class="step-badge ${badgeCls}">${badgeTxt}</span>
          <span class="step-toggle ${isOpen ? 'open' : ''}">▾</span>
        </div>
        <div class="step-card-body ${isOpen ? 'open' : ''}" id="sbody-${i}">
          ${toolsHtml}
          ${outputHtml}
          <div class="step-card-actions">${actionHtml}</div>
        </div>
      </div>
    `;
  }).join("");
}

// ═══════════════════════════════════════════
// MEMORY PANEL
// ═══════════════════════════════════════════
function renderMemoryPanel(b) {
  const mem = b.memory || {};
  const keys = Array.isArray(mem)
    ? []
    : (mem instanceof Map ? [...mem.keys()] : Object.keys(mem));

  document.getElementById("memBundleCount").textContent = keys.length + " keys";

  document.getElementById("memBundleEntries").innerHTML = keys.length
    ? keys.map(k => `
        <div class="memory-kv">
          <div class="mem-k">${esc(k)}</div>
          <div class="mem-v">${esc(mem instanceof Map ? mem.get(k) : mem[k])}</div>
        </div>
      `).join("")
    : `<div class="empty-state" style="padding:12px 0;">No bundle memory yet.</div>`;

  // Context summary
  if (b.contextSummary) {
    document.getElementById("memContextBox").textContent = b.contextSummary;
    document.getElementById("memContextBox").style.display = "";
    document.getElementById("memContextEmpty").style.display = "none";
  } else {
    document.getElementById("memContextBox").style.display = "none";
    document.getElementById("memContextEmpty").style.display = "";
  }

  renderWsMemory();
}

function renderWsMemory() {
  const wsM = STATE.wsMemory || {};
  const wsKeys = Object.keys(wsM);
  document.getElementById("memWsCount").textContent = wsKeys.length + " keys";
  document.getElementById("memWsEntries").innerHTML = wsKeys.length
    ? wsKeys.map(k => `
        <div class="memory-kv" style="border-left-color:var(--accent3)">
          <div class="mem-k" style="color:var(--accent3)">${esc(k)}</div>
          <div class="mem-v">${esc(wsM[k])}</div>
        </div>
      `).join("")
    : `<div class="empty-state" style="padding:12px 0;">No workspace memory yet.</div>`;
}

// ═══════════════════════════════════════════
// INSIGHT PANEL
// ═══════════════════════════════════════════
function renderInsightPanel(b) {
  const outputs = b.outputs || [];
  const all = [];
  outputs.forEach(o => {
    (o.keyInsights || []).forEach(k => {
      if (k) all.push({ insight: k, step: o.stepIndex, title: o.title });
    });
  });

  document.getElementById("insightList").innerHTML = all.length
    ? all.map(item => `
        <div class="insight-list-item">
          <span>${esc(item.insight)}</span>
        </div>
      `).join("")
    : `<div class="empty-state" style="padding:30px 0;">Key insights from step outputs will appear here.</div>`;
}

// ═══════════════════════════════════════════
// OUTPUT FEED
// ═══════════════════════════════════════════
function renderOutputFeed(outputs) {
  const feed = document.getElementById("outputFeed");
  if (!outputs || !outputs.length) {
    feed.innerHTML = `<div class="empty-state" style="padding:30px 0;">No outputs yet.</div>`;
    return;
  }
  feed.innerHTML = outputs.map(o => `
    <div class="output-feed-item">
      <div class="output-feed-meta">
        <span class="output-feed-step">Step ${(o.stepIndex ?? 0) + 1}${o.stepTitle ? ' · ' + esc(o.stepTitle) : ''}</span>
        <span class="output-feed-bundle">${esc(o.bundleTitle || '')}</span>
      </div>
      <div class="output-feed-preview">${esc(o.preview || '')}</div>
    </div>
  `).join("");
}

function pushOutputFeed(bundleTitle, stepIndex, stepTitle, content) {
  const feed = document.getElementById("outputFeed");
  const old  = feed.querySelector(".empty-state");
  if (old) old.remove();

  const item = document.createElement("div");
  item.className = "output-feed-item";
  item.innerHTML = `
    <div class="output-feed-meta">
      <span class="output-feed-step">Step ${stepIndex + 1}${stepTitle ? ' · ' + esc(stepTitle) : ''}</span>
      <span class="output-feed-bundle">${esc(bundleTitle)}</span>
    </div>
    <div class="output-feed-preview">${esc((content || '').substring(0, 240))}</div>
  `;
  feed.prepend(item);
}

// ═══════════════════════════════════════════
// ACTIONS
// ═══════════════════════════════════════════
async function runCurrentBundle() {
  const b = STATE.bundle;
  if (!b) return;
  try {
    const res  = await fetch("/workspace/run/" + b._id, { method: "POST" });
    const data = await res.json();
    if (data.error) { toast(data.error, "error"); return; }
    STATE.bundle = data.bundle;
    renderExecPanel(data.bundle);
    toast("Bundle started ▶", "success");
  } catch(e) { toast("Failed to run", "error"); }
}

async function pauseCurrentBundle() {
  const b = STATE.bundle;
  if (!b) return;
  try {
    await fetch("/workspace/pause/" + b._id, { method: "POST" });
    STATE.bundle.status = "paused";
    renderExecPanel(STATE.bundle);
    updateBundleRowDot(b._id, "paused");
    toast("Paused ⏸", "info");
  } catch(e) { toast("Failed to pause", "error"); }
}

async function resumeCurrentBundle() {
  const b = STATE.bundle;
  if (!b) return;
  try {
    const res  = await fetch("/workspace/resume/" + b._id, { method: "POST" });
    const data = await res.json();
    if (data.error) { toast(data.error, "error"); return; }
    STATE.bundle = data.bundle;
    renderExecPanel(data.bundle);
    updateBundleRowDot(b._id, "active");
    toast("Resumed ▶", "success");
  } catch(e) { toast("Failed to resume", "error"); }
}

async function markStepDone(stepIndex) {
  const b = STATE.bundle;
  if (!b) return;
  try {
    const res  = await fetch(`/workspace/step/${b._id}/${stepIndex}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ title: b.steps[stepIndex]?.title || ("Step " + (stepIndex+1)) }),
    });
    const data = await res.json();
    if (data.error) { toast(data.error, "error"); return; }
    STATE.bundle = data.bundle;
    renderExecPanel(data.bundle);
    renderMemoryPanel(data.bundle);
    renderInsightPanel(data.bundle);
    updateBundleRowProgress(b._id, data.bundle);
    toast("Step " + (stepIndex+1) + " complete ✓", "success");
  } catch(e) { toast("Error marking step", "error"); }
}

async function rerunStep(stepIndex) {
  const b = STATE.bundle;
  if (!b) return;
  // Reset progress for this step locally & reload
  (b.progress || []).forEach(p => { if (p.step === stepIndex) p.status = "pending"; });
  b.outputs = (b.outputs || []).filter(o => o.stepIndex !== stepIndex);
  renderExecPanel(b);
  toast("Step " + (stepIndex+1) + " reset — re-run when ready", "info");
}

async function pinCurrentBundle() {
  const b = STATE.bundle;
  if (!b) return;
  const id = b._id;
  try {
    if (STATE.pinnedIds.includes(id)) {
      await fetch("/workspace/unpin/" + id, { method: "POST" });
      STATE.pinnedIds = STATE.pinnedIds.filter(x => x !== id);
      document.getElementById("btnPin").textContent = "☆ PIN";
      toast("Unpinned", "info");
    } else {
      await fetch("/workspace/pin/" + id, { method: "POST" });
      STATE.pinnedIds.push(id);
      document.getElementById("btnPin").textContent = "★ PINNED";
      toast("Pinned ★", "success");
    }
  } catch(e) {}
}

// ═══════════════════════════════════════════
// CARD TOGGLES & NAVIGATION
// ═══════════════════════════════════════════
function toggleCard(idx) {
  const body   = document.getElementById("sbody-" + idx);
  const toggle = document.querySelector(`#scard-${idx} .step-toggle`);
  const isOpen = body.classList.contains("open");
  body.classList.toggle("open", !isOpen);
  if (toggle) toggle.classList.toggle("open", !isOpen);
  STATE.selectedStep = !isOpen ? idx : null;
}

function jumpToStep(idx) {
  STATE.selectedStep = idx;
  const card = document.getElementById("scard-" + idx);
  if (card) {
    card.scrollIntoView({ behavior: "smooth", block: "center" });
    // open it
    const body   = document.getElementById("sbody-" + idx);
    const toggle = document.querySelector(`#scard-${idx} .step-toggle`);
    body.classList.add("open");
    if (toggle) toggle.classList.add("open");
  }
}

// ═══════════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════════
function updateBreadcrumb(title) {
  document.getElementById("topBreadcrumb").textContent = title || "Bundle";
}

function updatePinBtn(id) {
  document.getElementById("btnPin").textContent =
    STATE.pinnedIds.includes(id) ? "★ PINNED" : "☆ PIN";
}

function updateBundleRowDot(id, status) {
  const row = document.getElementById("brow-" + id);
  if (!row) return;
  const dot = row.querySelector(".bundle-status-dot");
  if (!dot) return;
  dot.className = "bundle-status-dot " + (
    status === "active"    ? "dot-active"    :
    status === "paused"    ? "dot-paused"    :
    status === "completed" ? "dot-completed" : "dot-draft"
  );
}

function updateBundleRowProgress(id, bundle) {
  const row = document.getElementById("brow-" + id);
  if (!row) return;
  const steps = bundle.steps || [];
  const done  = (bundle.progress || []).filter(p => p.status === "completed").length;
  const pct   = steps.length ? Math.round((done / steps.length) * 100) : 0;
  const fill  = row.querySelector(".bundle-row-fill");
  const pctEl = row.querySelector(".bundle-row-pct");
  if (fill)  fill.style.width = pct + "%";
  if (pctEl) pctEl.textContent = pct + "%";
  updateBundleRowDot(id, bundle.status);
}

function launchTool(url) {
  if (!url) return;
  if (!url.startsWith("http")) url = "https://" + url;
  window.open(url, "_blank");
}

// ═══════════════════════════════════════════
// FORMATTERS
// ═══════════════════════════════════════════
function esc(str) {
  if (!str) return "";
  return String(str)
    .replace(/&/g,"&amp;").replace(/</g,"&lt;")
    .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}

function formatOutput(text) {
  if (!text) return "";
  return esc(text)
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/`([^`]+)`/g, "<code style='background:var(--panel);padding:1px 5px;border-radius:3px;font-family:var(--font-mono);font-size:0.85em;'>$1</code>")
    .replace(/\n/g, "<br/>");
}

// ═══════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════
let _toastTimer;
function toast(msg, type = "info") {
  clearTimeout(_toastTimer);
  document.querySelectorAll(".toast").forEach(e => e.remove());
  const el = document.createElement("div");
  el.className = `toast toast-${type}`;
  el.textContent = msg;
  document.body.appendChild(el);
  _toastTimer = setTimeout(() => el.remove(), 3000);
}
</script>
</body>
</html>
