async function loadProjectList() {
  try {
    const res  = await fetch("/workspace/projects");
    if (!res.ok) return;
    const data = await res.json();
    renderProjectList(data.projects || []);
  } catch(e) { console.warn("[AQ] loadProjectList:", e.message); }
}

function renderProjectList(projects) {
  const container = document.getElementById("projectListItems");
  if (!projects.length) {
    container.innerHTML = `<div class="aq-empty"><span class="aq-empty-icon">📁</span>No projects yet.</div>`;
    return;
  }
  container.innerHTML = projects.map(p => `
    <div class="aq-proj-item ${STATE.projectId === String(p._id || p.id) ? 'active' : ''}"
         id="prow-${p._id || p.id}"
         onclick="openProject('${p._id || p.id}','${esc(p.name)}')">
      <span class="aq-proj-icon">📁</span>
      <span class="aq-proj-name">${esc(p.name)}</span>
      <button class="aq-proj-del" onclick="event.stopPropagation();deleteProject('${p._id || p.id}')" title="Delete">✕</button>
    </div>`).join("");
}

async function promptNewProject() {
  const name = window.prompt("Project name:");
  if (!name || !name.trim()) return;
  showLoading();
  try {
    const res  = await fetch("/workspace/projects", { method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({ name: name.trim() }) });
    const data = await res.json();
    if (!data.success) throw new Error(data.error || "Create failed");
    await loadProjectList();
    const id = data.project?._id || data.project?.id;
    if (id) openProject(id, name.trim());
    toast("Project created", "success");
  } catch(e) { toast("Error: " + e.message, "error"); }
  finally { hideLoading(); }
}

