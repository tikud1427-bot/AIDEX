<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Workspace | Aquiplex</title>
<link rel="stylesheet" href="/css/styles.css">
<link rel="stylesheet" href="/css/workspace.css">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<link rel="icon" type="image/png" sizes="96x96" href="https://aquiplex.com/logo/favicon-96x96.png">
<link rel="icon" type="image/svg+xml" href="https://aquiplex.com/logo/favicon.svg">
<link rel="shortcut icon" href="https://aquiplex.com/logo/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="https://aquiplex.com/logo/apple-touch-icon.png">
<script src="/socket.io/socket.io.js"></script>

<style>
/* ─── RESET & VARIABLES ─── */
:root {
  --bg:        #0a0a0f;
  --surface:   #111118;
  --surface2:  #18181f;
  --border:    #2a2a3a;
  --accent:    #6ee7b7;
  --accent2:   #818cf8;
  --accent3:   #f472b6;
  --text:      #e2e8f0;
  --muted:     #64748b;
  --danger:    #f87171;
  --mono:      'IBM Plex Mono', monospace;
  --sans:      'Syne', sans-serif;
  --radius:    6px;
  --topbar-h:  52px;
}

*,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
html,body { height: 100%; overflow: hidden; background: var(--bg); color: var(--text); font-family: var(--mono); font-size: 13px; }

/* ─── LAYOUT ─── */
.aq-workspace { display: flex; flex-direction: column; height: 100vh; }

.aq-topbar {
  height: var(--topbar-h);
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0 16px;
  flex-shrink: 0;
  z-index: 50;
}

.aq-logo {
  font-family: var(--sans);
  font-weight: 800;
  font-size: 1rem;
  letter-spacing: 0.08em;
  color: var(--accent);
  flex-shrink: 0;
}
.aq-logo span { color: var(--muted); }

.aq-topbar-prompt {
  flex: 1;
  display: flex;
  gap: 8px;
  align-items: center;
  min-width: 0;
  max-width: 680px;
}
.aq-topbar-prompt input {
  flex: 1;
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  font-family: var(--mono);
  font-size: 0.78rem;
  padding: 7px 12px;
  border-radius: var(--radius);
  outline: none;
  transition: border-color 0.15s;
  min-width: 0;
}
.aq-topbar-prompt input:focus { border-color: var(--accent); }
.aq-topbar-prompt input::placeholder { color: var(--muted); }

.aq-body {
  display: flex;
  flex: 1;
  min-height: 0;
}

/* ─── SIDEBAR ─── */
.aq-sidebar {
  width: 220px;
  flex-shrink: 0;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  min-height: 0;
}
.aq-sidebar-hdr {
  padding: 12px 14px 8px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.aq-sidebar-title {
  font-family: var(--sans);
  font-weight: 700;
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
}
.aq-sidebar-tabs {
  display: flex;
  border-bottom: 1px solid var(--border);
}
.aq-sidebar-tab {
  flex: 1;
  padding: 7px 4px;
  background: none;
  border: none;
  color: var(--muted);
  font-family: var(--mono);
  font-size: 0.65rem;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s;
  letter-spacing: 0.05em;
}
.aq-sidebar-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.aq-sidebar-tab:hover:not(.active) { color: var(--text); }

.aq-sidebar-list {
  flex: 1;
  overflow-y: auto;
  padding: 6px 0;
}
.aq-sidebar-list::-webkit-scrollbar { width: 3px; }
.aq-sidebar-list::-webkit-scrollbar-thumb { background: var(--border); }

/* ─── PROJECT ITEMS ─── */
.aq-proj-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  cursor: pointer;
  border-left: 2px solid transparent;
  transition: background 0.1s, border-color 0.1s;
  position: relative;
}
.aq-proj-item:hover { background: var(--surface2); }
.aq-proj-item.active { background: var(--surface2); border-left-color: var(--accent); }
.aq-proj-icon { font-size: 0.85rem; flex-shrink: 0; }
.aq-proj-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 0.72rem;
  color: var(--text);
}
.aq-proj-del {
  background: none;
  border: none;
  color: var(--muted);
  cursor: pointer;
  font-size: 0.65rem;
  padding: 2px 4px;
  border-radius: 3px;
  opacity: 0;
  transition: opacity 0.1s, color 0.1s;
}
.aq-proj-item:hover .aq-proj-del { opacity: 1; }
.aq-proj-del:hover { color: var(--danger); }

/* ─── BUNDLE ITEMS ─── */
.aq-bundle-item {
  padding: 8px 14px;
  cursor: pointer;
  border-left: 2px solid transparent;
  transition: background 0.1s, border-color 0.1s;
}
.aq-bundle-item:hover { background: var(--surface2); }
.aq-bundle-item.selected { background: var(--surface2); border-left-color: var(--accent2); }
.aq-bundle-row1 { display: flex; align-items: center; gap: 7px; }
.aq-bundle-title { font-size: 0.72rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; min-width: 0; }
.aq-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.aq-dot-active { background: var(--accent); box-shadow: 0 0 6px var(--accent); animation: pulse 2s infinite; }
.aq-dot-paused { background: #fbbf24; }
.aq-dot-completed { background: var(--accent2); }
.aq-dot-draft { background: var(--muted); }
.aq-bundle-meta { display: flex; align-items: center; gap: 6px; margin-top: 4px; }
.aq-bundle-track { flex: 1; height: 2px; background: var(--border); border-radius: 1px; }
.aq-bundle-fill { height: 100%; background: var(--accent2); border-radius: 1px; transition: width 0.4s; }
.aq-bundle-pct { font-size: 0.58rem; color: var(--muted); }

/* ─── MAIN AREA ─── */
.aq-main { display: flex; flex: 1; min-width: 0; min-height: 0; }

/* ─── CODE EDITOR PANE ─── */
.aq-editor-pane {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  min-height: 0;
  border-right: 1px solid var(--border);
}

.aq-file-tabs {
  display: flex;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  flex-shrink: 0;
}
.aq-file-tabs::-webkit-scrollbar { height: 2px; }
.aq-file-tabs::-webkit-scrollbar-thumb { background: var(--border); }

.aq-file-tab {
  padding: 8px 14px;
  background: none;
  border: none;
  border-right: 1px solid var(--border);
  color: var(--muted);
  font-family: var(--mono);
  font-size: 0.68rem;
  cursor: pointer;
  white-space: nowrap;
  border-bottom: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s, background 0.1s;
  display: flex;
  align-items: center;
  gap: 5px;
}
.aq-file-tab.active { color: var(--text); background: var(--surface2); border-bottom-color: var(--accent); }
.aq-file-tab:hover:not(.active) { color: var(--text); background: var(--surface2); }
.aq-file-tab-close {
  font-size: 0.6rem;
  opacity: 0.4;
  line-height: 1;
  transition: opacity 0.1s;
}
.aq-file-tab:hover .aq-file-tab-close { opacity: 0.9; }

.aq-editor-toolbar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.aq-editor-filename {
  flex: 1;
  font-size: 0.68rem;
  color: var(--muted);
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.aq-code-editor {
  flex: 1;
  min-height: 0;
  width: 100%;
  resize: none;
  background: var(--bg);
  color: var(--text);
  font-family: var(--mono);
  font-size: 0.76rem;
  line-height: 1.6;
  padding: 14px 16px;
  border: none;
  outline: none;
  tab-size: 2;
  white-space: pre;
  overflow-wrap: normal;
  overflow-x: auto;
}

/* ─── AI EDIT BAR ─── */
.aq-ai-edit-bar {
  display: flex;
  gap: 8px;
  align-items: center;
  padding: 8px 12px;
  background: var(--surface);
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}
.aq-ai-edit-bar input {
  flex: 1;
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  font-family: var(--mono);
  font-size: 0.72rem;
  padding: 6px 10px;
  border-radius: var(--radius);
  outline: none;
  transition: border-color 0.15s;
}
.aq-ai-edit-bar input:focus { border-color: var(--accent2); }
.aq-ai-edit-bar input::placeholder { color: var(--muted); }

/* ─── PREVIEW PANE ─── */
.aq-preview-pane {
  width: 42%;
  min-width: 280px;
  display: flex;
  flex-direction: column;
  background: var(--surface);
  flex-shrink: 0;
}
.aq-preview-header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.aq-preview-dots { display: flex; gap: 5px; }
.aq-preview-dots span { width: 10px; height: 10px; border-radius: 50%; display: block; }
.aq-preview-url {
  flex: 1;
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--muted);
  font-size: 0.65rem;
  padding: 4px 8px;
  border-radius: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.aq-preview-iframe {
  flex: 1;
  border: none;
  background: #fff;
  width: 100%;
}

/* ─── WELCOME / EMPTY STATE ─── */
.aq-welcome {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14px;
  padding: 40px;
  text-align: center;
}
.aq-welcome-glyph { font-size: 2.5rem; opacity: 0.25; }
.aq-welcome h2 { font-family: var(--sans); font-weight: 700; font-size: 1.2rem; color: var(--text); }
.aq-welcome p { font-size: 0.75rem; color: var(--muted); max-width: 340px; line-height: 1.7; }
.aq-welcome-hint { font-size: 0.62rem; color: var(--muted); margin-top: 6px; }

/* ─── EXEC PANEL ─── */
.aq-exec { display: flex; flex-direction: column; flex: 1; min-height: 0; overflow: hidden; }
.aq-exec-hdr { padding: 14px 18px; background: var(--surface); border-bottom: 1px solid var(--border); flex-shrink: 0; }
.aq-exec-hdr-top { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
.aq-exec-title { font-family: var(--sans); font-weight: 700; font-size: 0.95rem; }
.aq-exec-goal { font-size: 0.7rem; color: var(--muted); margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.aq-exec-actions { display: flex; gap: 6px; flex-wrap: wrap; }
.aq-stats-row { display: flex; gap: 18px; margin: 8px 0; flex-wrap: wrap; }
.aq-stat { display: flex; flex-direction: column; gap: 2px; }
.aq-stat-val { font-family: var(--sans); font-weight: 700; font-size: 1rem; }
.aq-stat-lbl { font-size: 0.58rem; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; }
.c-accent { color: var(--accent); } .c-green { color: #4ade80; } .c-amber { color: #fbbf24; } .c-purple { color: var(--accent2); }
.aq-progress-track { height: 3px; background: var(--border); border-radius: 2px; position: relative; overflow: visible; margin-top: 6px; }
.aq-progress-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2)); border-radius: 2px; transition: width 0.5s; }
.aq-progress-glow { position: absolute; top: -4px; width: 8px; height: 11px; background: var(--accent); border-radius: 4px; transform: translateX(-50%); transition: left 0.5s; opacity: 0.7; }
.aq-exec-content { display: flex; flex: 1; min-height: 0; gap: 0; }
.aq-steps-panel { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.aq-timeline { display: flex; align-items: center; padding: 10px 18px; gap: 0; background: var(--surface); border-bottom: 1px solid var(--border); overflow-x: auto; flex-shrink: 0; }
.aq-timeline::-webkit-scrollbar { height: 2px; } .aq-timeline::-webkit-scrollbar-thumb { background: var(--border); }
.aq-tl-step { display: flex; align-items: center; cursor: pointer; }
.aq-tl-dot { width: 22px; height: 22px; border-radius: 50%; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 0.58rem; color: var(--muted); transition: all 0.2s; background: var(--surface); flex-shrink: 0; }
.aq-tl-dot.done { background: var(--accent2); border-color: var(--accent2); color: #fff; }
.aq-tl-dot.running { border-color: var(--accent); color: var(--accent); animation: pulse 1.5s infinite; }
.aq-tl-line { width: 20px; height: 2px; background: var(--border); flex-shrink: 0; }
.aq-tl-line.done { background: var(--accent2); }
.aq-steps-scroll { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 8px; }
.aq-steps-scroll::-webkit-scrollbar { width: 3px; } .aq-steps-scroll::-webkit-scrollbar-thumb { background: var(--border); }
.aq-step-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; transition: border-color 0.2s; }
.aq-step-card.active { border-color: var(--accent); }
.aq-step-card.done { border-color: var(--accent2); }
.aq-step-card.running { border-color: var(--accent); box-shadow: 0 0 12px rgba(110,231,183,0.1); }
.aq-step-hdr { display: flex; align-items: center; gap: 10px; padding: 10px 14px; cursor: pointer; user-select: none; }
.aq-step-hdr:hover { background: var(--surface2); }
.aq-step-num { width: 22px; height: 22px; border-radius: 50%; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 0.6rem; flex-shrink: 0; transition: all 0.2s; }
.aq-step-num.done { background: var(--accent2); border-color: var(--accent2); color: #fff; }
.aq-step-num.running { border-color: var(--accent); color: var(--accent); }
.aq-step-info { flex: 1; min-width: 0; }
.aq-step-title { font-size: 0.75rem; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.aq-step-desc { font-size: 0.65rem; color: var(--muted); margin-top: 1px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.aq-badge { font-size: 0.56rem; padding: 2px 6px; border-radius: 3px; letter-spacing: 0.07em; font-weight: 600; flex-shrink: 0; }
.wb-done { background: rgba(129,140,248,0.15); color: var(--accent2); }
.wb-running { background: rgba(110,231,183,0.1); color: var(--accent); }
.wb-pending { background: var(--surface2); color: var(--muted); }
.wb-failed { background: rgba(248,113,113,0.15); color: var(--danger); }
.aq-step-toggle { color: var(--muted); font-size: 0.7rem; transition: transform 0.2s; flex-shrink: 0; }
.aq-step-toggle.open { transform: rotate(180deg); }
.aq-step-body { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
.aq-step-body-inner { padding: 10px 14px 12px; border-top: 1px solid var(--border); }
.aq-output-block { background: var(--surface2); border: 1px solid var(--border); border-radius: 4px; padding: 10px 12px; margin-bottom: 8px; }
.aq-output-hdr { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.aq-output-label { font-size: 0.62rem; color: var(--accent); font-weight: 600; letter-spacing: 0.08em; }
.aq-output-badges { display: flex; gap: 4px; flex: 1; }
.aq-out-meta-badge { font-size: 0.56rem; padding: 1px 5px; border-radius: 3px; }
.aq-out-meta-badge.green { background: rgba(74,222,128,0.1); color: #4ade80; }
.aq-out-meta-badge.muted { background: var(--border); color: var(--muted); }
.aq-output-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); opacity: 0.6; }
.aq-output-content { font-size: 0.7rem; line-height: 1.7; color: var(--text); overflow-x: auto; word-break: break-word; }
.aq-output-content strong { color: var(--accent2); }
.aq-out-h2 { display: block; color: var(--accent); font-size: 0.75rem; font-weight: 700; margin: 6px 0 2px; font-family: var(--sans); }
.aq-out-li { display: block; padding-left: 10px; color: var(--text); opacity: 0.85; }
.aq-out-code { background: var(--border); border-radius: 3px; padding: 1px 4px; font-size: 0.67rem; color: var(--accent3); }
.aq-step-actions { display: flex; gap: 6px; margin-top: 8px; }
.aq-step-act-btn { background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: var(--mono); font-size: 0.65rem; padding: 4px 10px; border-radius: var(--radius); cursor: pointer; transition: all 0.15s; display: flex; align-items: center; gap: 5px; }
.aq-step-act-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
.aq-step-act-btn.run-step:hover:not(:disabled) { background: rgba(110,231,183,0.08); }
.aq-step-act-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.aq-insight-chips { display: flex; flex-wrap: wrap; gap: 5px; }
.aq-insight-chip { font-size: 0.6rem; background: rgba(129,140,248,0.1); border: 1px solid rgba(129,140,248,0.2); color: var(--accent2); padding: 2px 7px; border-radius: 10px; }
.aq-empty-inline { font-size: 0.68rem; color: var(--muted); padding: 6px 0; }
.aq-output-loading { display: flex; }
.aq-spinner-row { display: flex; align-items: center; gap: 8px; font-size: 0.7rem; color: var(--muted); }
.aq-tool-chips { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 8px; }
.aq-tool-chip { font-size: 0.6rem; background: var(--surface2); border: 1px solid var(--border); padding: 2px 7px; border-radius: 10px; color: var(--muted); text-decoration: none; }
.aq-right-panel { width: 260px; flex-shrink: 0; border-left: 1px solid var(--border); display: flex; flex-direction: column; background: var(--surface); }
.aq-right-tabs { display: flex; border-bottom: 1px solid var(--border); }
.aq-right-tab { flex: 1; padding: 7px 4px; background: none; border: none; color: var(--muted); font-family: var(--mono); font-size: 0.62rem; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s; letter-spacing: 0.04em; }
.aq-right-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.aq-right-body { flex: 1; overflow-y: auto; padding: 10px; }
.aq-right-section { display: none; }
.aq-right-section.active { display: block; transition: opacity 0.2s; }
.aq-feed-item { background: var(--surface2); border: 1px solid var(--border); border-radius: 4px; padding: 8px 10px; margin-bottom: 6px; }
.aq-feed-item-new { opacity: 0; transition: opacity 0.3s; }
.aq-feed-item-new.visible { opacity: 1; }
.aq-feed-meta { display: flex; justify-content: space-between; margin-bottom: 4px; gap: 8px; }
.aq-feed-step { font-size: 0.62rem; color: var(--accent); }
.aq-feed-bundle { font-size: 0.58rem; color: var(--muted); }
.aq-feed-preview { font-size: 0.65rem; color: var(--text); opacity: 0.7; line-height: 1.5; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.aq-mem-hdr { font-size: 0.6rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
.aq-mem-hdr span { color: var(--accent); font-size: 0.56rem; }
.aq-mem-kv { background: var(--surface2); border-left: 2px solid var(--accent2); padding: 5px 8px; border-radius: 0 4px 4px 0; margin-bottom: 4px; }
.aq-mem-k { font-size: 0.6rem; color: var(--accent2); margin-bottom: 2px; }
.aq-mem-v { font-size: 0.65rem; color: var(--text); word-break: break-word; }
.aq-context-box { background: var(--surface2); border: 1px solid var(--border); border-radius: 4px; padding: 8px; font-size: 0.65rem; line-height: 1.5; color: var(--text); }
.aq-insight-item { display: flex; align-items: center; font-size: 0.68rem; padding: 6px 8px; background: var(--surface2); border-radius: 4px; margin-bottom: 4px; line-height: 1.4; }
.aq-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; padding: 20px; text-align: center; color: var(--muted); font-size: 0.7rem; }
.aq-empty-icon { font-size: 1.5rem; opacity: 0.3; }

/* ─── BUTTONS ─── */
.aq-btn { background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: var(--mono); font-size: 0.68rem; padding: 6px 14px; border-radius: var(--radius); cursor: pointer; transition: all 0.15s; white-space: nowrap; letter-spacing: 0.04em; }
.aq-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
.aq-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.aq-btn-sm { padding: 4px 10px; font-size: 0.64rem; }
.aq-btn-run { background: rgba(110,231,183,0.1); border-color: var(--accent); color: var(--accent); }
.aq-btn-run:hover:not(:disabled) { background: rgba(110,231,183,0.2); }
.aq-btn-ai { background: rgba(129,140,248,0.1); border-color: var(--accent2); color: var(--accent2); }
.aq-btn-ai:hover:not(:disabled) { background: rgba(129,140,248,0.2); }
.aq-btn-danger { border-color: var(--danger); color: var(--danger); }
.aq-btn-danger:hover:not(:disabled) { background: rgba(248,113,113,0.1); }
.aq-btn-success { border-color: var(--accent); color: var(--accent); }

/* ─── SPINNER ─── */
.aq-spinner { width: 14px; height: 14px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.7s linear infinite; flex-shrink: 0; }
.aq-spinner-sm { width: 10px; height: 10px; }
.aq-mini-spinner { width: 10px; height: 10px; border: 1.5px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.7s linear infinite; display: inline-block; }

/* ─── MODALS ─── */
.aq-modal-backdrop,.aq-confirm-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: none; align-items: center; justify-content: center; z-index: 1000; }
.aq-modal-backdrop.open,.aq-confirm-backdrop.open { display: flex; }
.aq-modal { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; width: min(500px, 94vw); max-height: 80vh; display: flex; flex-direction: column; }
.aq-modal-hdr { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-bottom: 1px solid var(--border); }
.aq-modal-title { font-family: var(--sans); font-weight: 700; font-size: 0.85rem; }
.aq-modal-close { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 0.9rem; transition: color 0.15s; }
.aq-modal-close:hover { color: var(--danger); }
.aq-modal-body { flex: 1; overflow-y: auto; padding: 16px; }
.aq-modal-footer { padding: 10px 16px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; }
.aq-run-spinner { display: flex; align-items: center; gap: 10px; color: var(--muted); font-size: 0.75rem; }
.aq-run-output-label { font-size: 0.65rem; color: var(--accent); margin-bottom: 8px; letter-spacing: 0.08em; }
.aq-run-output-content { font-size: 0.72rem; line-height: 1.7; color: var(--text); }
.aq-confirm-box { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; width: min(380px, 94vw); padding: 20px; }
.aq-confirm-title { font-family: var(--sans); font-weight: 700; margin-bottom: 8px; font-size: 0.9rem; }
.aq-confirm-msg { font-size: 0.72rem; color: var(--muted); margin-bottom: 16px; line-height: 1.6; }
.aq-confirm-actions { display: flex; justify-content: flex-end; gap: 8px; }

/* ─── PALETTE ─── */
.aq-palette-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.6); display: none; align-items: flex-start; justify-content: center; padding-top: 15vh; z-index: 999; }
.aq-palette-backdrop.open { display: flex; }
.aq-palette { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; width: min(520px, 92vw); max-height: 60vh; display: flex; flex-direction: column; box-shadow: 0 20px 60px rgba(0,0,0,0.5); }
.aq-palette-input { background: transparent; border: none; border-bottom: 1px solid var(--border); color: var(--text); font-family: var(--mono); font-size: 0.85rem; padding: 14px 16px; outline: none; }
.aq-palette-list { flex: 1; overflow-y: auto; }
.aq-palette-cmd { padding: 10px 16px; cursor: pointer; font-size: 0.75rem; display: flex; align-items: center; justify-content: space-between; transition: background 0.1s; }
.aq-palette-cmd:hover { background: var(--surface2); }
.aq-palette-cmd .key { font-size: 0.58rem; color: var(--muted); background: var(--border); padding: 2px 5px; border-radius: 3px; }

/* ─── LOADING BAR ─── */
.aq-loading-bar { position: fixed; top: 0; left: 0; height: 2px; width: 0; background: linear-gradient(90deg, var(--accent), var(--accent2)); transition: width 0.3s; z-index: 9999; }
.aq-loading-bar.visible { animation: loadbar 1.5s ease-in-out infinite; }

/* ─── TOAST ─── */
#aq-toast-root { position: fixed; bottom: 20px; right: 20px; display: flex; flex-direction: column; gap: 6px; z-index: 9999; }
.aq-toast { background: var(--surface); border: 1px solid var(--border); padding: 10px 16px; border-radius: var(--radius); font-size: 0.72rem; max-width: 280px; transition: opacity 0.32s; box-shadow: 0 4px 20px rgba(0,0,0,0.4); }
.aq-toast.success { border-color: var(--accent); color: var(--accent); }
.aq-toast.error { border-color: var(--danger); color: var(--danger); }
.aq-toast.info { border-color: var(--accent2); color: var(--accent2); }
.aq-toast.fadeout { opacity: 0; }

/* ─── SKELETON ─── */
.aq-skeleton { background: linear-gradient(90deg, var(--surface) 25%, var(--surface2) 50%, var(--surface) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: var(--radius); }

/* ─── ANIMATIONS ─── */
@keyframes spin { to { transform: rotate(360deg); } }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
@keyframes loadbar { 0%{width:0;left:0;} 50%{width:60%;left:20%;} 100%{width:0;left:100%;} }
@keyframes shimmer { 0%{background-position:200% 0;} 100%{background-position:-200% 0;} }

/* ─── RESPONSIVE ─── */
@media (max-width: 768px) {
  .aq-preview-pane { display: none; }
  .aq-right-panel { display: none !important; }
  .aq-sidebar { width: 100%; position: absolute; z-index: 200; top: var(--topbar-h); bottom: 0; left: -100%; transition: left 0.25s; }
  .aq-sidebar.open { left: 0; }
}
@media (max-width: 600px) {
  .aq-topbar-prompt { max-width: unset; }
}

/* ─── STATUS PILL ─── */
.aq-status-pill { display: flex; align-items: center; gap: 5px; font-size: 0.6rem; color: var(--muted); letter-spacing: 0.08em; }
.aq-status-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 6px var(--accent); animation: pulse 2s infinite; }

/* ─── SWITCHER ─── */
.aq-switcher { background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: var(--mono); font-size: 0.68rem; padding: 4px 8px; border-radius: var(--radius); outline: none; cursor: pointer; }

/* ─── STEP BODY SETTLED STATE ─── */
.aq-step-body[data-state="settled"] { max-height: none !important; overflow: visible !important; }

/* ─── OVERFLOW FIXES ─── */
.aq-workspace,.aq-body,.aq-main,.aq-exec,.aq-exec-content,.aq-steps-panel,.aq-steps-scroll { min-width: 0; }

/* ─── PROJECT GENERATOR LOADING OVERLAY ─── */
.aq-gen-overlay {
  position: absolute; inset: 0;
  background: rgba(10,10,15,0.85);
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px;
  z-index: 100; backdrop-filter: blur(4px);
  border-radius: var(--radius);
}
.aq-gen-overlay-msg { font-size: 0.78rem; color: var(--accent); animation: pulse 1.5s infinite; }
.aq-editor-pane { position: relative; }

/* ─── MENU BTN ─── */
.aq-menu-btn { background: none; border: none; color: var(--muted); font-size: 1rem; cursor: pointer; padding: 4px; transition: color 0.15s; display: none; }
.aq-menu-btn:hover { color: var(--text); }
@media (max-width: 768px) { .aq-menu-btn { display: block; } }

/* ─── BREADCRUMB ─── */
.aq-breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 0.68rem; color: var(--muted); }
.aq-breadcrumb .cur { color: var(--text); }
</style>
</head>
<body>

<%- include('partials/nav') %>

<div class="aq-loading-bar" id="aqLoadingBar"></div>
<div id="aq-toast-root"></div>

<!-- ═══ STEP RUN MODAL ═══ -->
<div class="aq-modal-backdrop" id="aqRunModal">
  <div class="aq-modal">
    <div class="aq-modal-hdr">
      <span class="aq-modal-title" id="runModalTitle">Running Step…</span>
      <button class="aq-modal-close" onclick="closeRunModal()">✕</button>
    </div>
    <div class="aq-modal-body">
      <div class="aq-run-spinner" id="runModalSpinner">
        <div class="aq-spinner"></div><span>Executing step…</span>
      </div>
      <div class="aq-run-output" id="runModalOutput" style="display:none;">
        <div class="aq-run-output-label">⚡ Output</div>
        <div class="aq-run-output-content" id="runModalOutputContent"></div>
      </div>
    </div>
    <div class="aq-modal-footer" id="runModalFooter" style="display:none;">
      <button class="aq-btn aq-btn-sm aq-btn-success" onclick="closeRunModal()">✓ Done</button>
    </div>
  </div>
</div>

<!-- ═══ COMMAND PALETTE ═══ -->
<div class="aq-palette-backdrop" id="aqPalette" onclick="closePalette(event)">
  <div class="aq-palette">
    <input class="aq-palette-input" id="aqPaletteInput" placeholder="Type a command…"
           oninput="filterPalette(this.value)" onkeydown="paletteKeydown(event)"/>
    <div class="aq-palette-list" id="aqPaletteList"></div>
  </div>
</div>

<!-- ═══ CONFIRM MODAL ═══ -->
<div class="aq-confirm-backdrop" id="aqConfirm">
  <div class="aq-confirm-box">
    <div class="aq-confirm-title" id="aqConfirmTitle">Are you sure?</div>
    <div class="aq-confirm-msg"   id="aqConfirmMsg"></div>
    <div class="aq-confirm-actions">
      <button class="aq-btn aq-btn-sm" onclick="resolveConfirm(false)">Cancel</button>
      <button class="aq-btn aq-btn-sm aq-btn-danger" id="aqConfirmOk" onclick="resolveConfirm(true)">Confirm</button>
    </div>
  </div>
</div>

<div class="workspace-page aq-workspace">

  <!-- ═══ TOPBAR ═══ -->
  <div class="aq-topbar">
    <button class="aq-menu-btn" id="menuBtn" aria-label="Open menu" onclick="openSidebar()">☰</button>
    <div class="aq-logo">AQUI<span>PLEX</span></div>
    <div class="aq-breadcrumb"><span class="cur" id="topBreadcrumb">Workspace</span></div>

    <!-- Generate bar (shared, always visible) -->
    <div class="aq-topbar-prompt">
      <input id="topPromptInput" placeholder="What do you want to build? Press Enter to generate…"
             onkeydown="if(event.key==='Enter')generateProject()"/>
      <button class="aq-btn aq-btn-run aq-btn-sm" id="topGenBtn" onclick="generateProject()">⚡ Generate</button>
    </div>

    <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
      <div class="aq-status-pill">
        <div class="aq-status-dot"></div><span>ONLINE</span>
      </div>
      <select id="bundleSwitcher" class="aq-switcher" title="Switch bundle" style="display:none;"></select>
      <button class="aq-btn aq-btn-sm" onclick="openPalette()" title="Command palette">⌘K</button>
    </div>
  </div>

  <!-- ═══ BODY ═══ -->
  <div class="aq-body">

    <!-- ═══ LEFT SIDEBAR ═══ -->
    <div class="aq-sidebar" id="aqSidebar">
      <div class="aq-sidebar-hdr">
        <span class="aq-sidebar-title">Workspace</span>
        <button class="aq-btn aq-btn-sm" onclick="closeSidebar()" style="display:none;" id="sidebarCloseBtn">✕</button>
      </div>
      <div class="aq-sidebar-tabs">
        <button class="aq-sidebar-tab active" onclick="switchLeftTab('projects', this)">Projects</button>
        <button class="aq-sidebar-tab"        onclick="switchLeftTab('bundles',  this)">Bundles</button>
      </div>

      <!-- PROJECTS LIST -->
      <div class="aq-sidebar-list" id="leftProjectList">
        <div style="padding:8px 10px;">
          <button class="aq-btn aq-btn-sm" onclick="promptNewProject()" style="width:100%;">+ New Project</button>
        </div>
        <div id="projectListItems">
          <div class="aq-empty"><span class="aq-empty-icon">📁</span>No projects yet.</div>
        </div>
      </div>

      <!-- BUNDLES LIST -->
      <div class="aq-sidebar-list" id="leftBundleList" style="display:none;">
        <% if (bundles && bundles.length > 0) { %>
          <% bundles.forEach(function(b) {
            const completed = (b.progress || []).filter(p => p && p.status === 'completed').length;
            const total     = (b.steps || []).length;
            const pct       = total > 0 ? Math.round((completed / total) * 100) : 0;
            const dotCls    = b.status === 'active'    ? 'aq-dot-active'
                            : b.status === 'paused'    ? 'aq-dot-paused'
                            : b.status === 'completed' ? 'aq-dot-completed'
                            : 'aq-dot-draft';
          %>
          <div class="aq-bundle-item" id="brow-<%= b._id %>" onclick="selectBundleById('<%= b._id %>')">
            <div class="aq-bundle-row1">
              <div class="aq-dot <%= dotCls %>"></div>
              <div class="aq-bundle-title"><%= b.title %></div>
            </div>
            <div class="aq-bundle-meta">
              <div class="aq-bundle-track"><div class="aq-bundle-fill" style="width:<%= pct %>%"></div></div>
              <div class="aq-bundle-pct"><%= pct %>%</div>
            </div>
          </div>
          <% }) %>
        <% } else { %>
          <div class="aq-empty">
            <span class="aq-empty-icon">📦</span>
            No bundles yet.<br/>
            <a href="/bundles" style="color:var(--accent);font-size:0.7rem;margin-top:4px;display:inline-block;">Create bundle →</a>
          </div>
        <% } %>
      </div>
    </div>

    <!-- ═══ MAIN ═══ -->
    <div class="aq-main">

      <!-- ─── PROJECT VIEW (code editor + preview) ─── -->
      <div id="wsProjectView" style="display:none;flex:1;min-width:0;min-height:0;display:none;">

        <!-- Code Editor Pane -->
        <div class="aq-editor-pane" id="editorPane">
          <!-- File tabs -->
          <div class="aq-file-tabs" id="fileTabs"></div>
          <!-- Toolbar -->
          <div class="aq-editor-toolbar">
            <span class="aq-editor-filename" id="editorFilename">No file selected</span>
            <button class="aq-btn aq-btn-sm aq-btn-success" onclick="saveCurrentFile()">💾 Save</button>
          </div>
          <!-- Code textarea -->
          <textarea class="aq-code-editor" id="codeEditor" spellcheck="false"
                    placeholder="Select a file from the tabs above…"
                    oninput="markDirty()"></textarea>
          <!-- AI Edit bar -->
          <div class="aq-ai-edit-bar">
            <input id="aiEditInput" placeholder="Describe an edit: 'Make the navbar sticky', 'Add dark mode toggle'…"
                   onkeydown="if(event.key==='Enter')aiEditFile()"/>
            <button class="aq-btn aq-btn-ai aq-btn-sm" id="aiEditBtn" onclick="aiEditFile()">✦ AI Edit</button>
          </div>
          <!-- Generating overlay -->
          <div class="aq-gen-overlay" id="genOverlay" style="display:none;">
            <div class="aq-spinner" style="width:22px;height:22px;border-width:3px;"></div>
            <div class="aq-gen-overlay-msg" id="genOverlayMsg">Generating project…</div>
          </div>
        </div>

        <!-- Preview Pane -->
        <div class="aq-preview-pane">
          <div class="aq-preview-header">
            <div class="aq-preview-dots">
              <span style="background:#ff5f57;"></span>
              <span style="background:#ffbd2e;"></span>
              <span style="background:#28c940;"></span>
            </div>
            <div class="aq-preview-url" id="previewUrl">about:blank</div>
            <button class="aq-btn aq-btn-sm" onclick="refreshPreview()" title="Reload" style="padding:3px 8px;font-size:0.6rem;">⟳</button>
          </div>
          <iframe id="previewFrame" class="aq-preview-iframe" sandbox="allow-scripts allow-same-origin" title="Preview"></iframe>
        </div>
      </div>

      <!-- ─── BUNDLE EXEC VIEW ─── -->
      <div class="aq-exec" id="wsExec" style="display:none;">
        <div class="aq-exec-hdr">
          <div class="aq-exec-hdr-top">
            <div style="flex:1;min-width:0;">
              <div class="aq-exec-title" id="execTitle">—</div>
              <div class="aq-exec-goal"  id="execGoal">—</div>
            </div>
            <div class="aq-exec-actions">
              <button class="aq-btn aq-btn-sm aq-btn-run" id="btnRun"    onclick="runCurrentBundle()">▶ Run</button>
              <button class="aq-btn aq-btn-sm"            id="btnPause"  onclick="pauseCurrentBundle()"  style="display:none;">⏸ Pause</button>
              <button class="aq-btn aq-btn-sm"            id="btnResume" onclick="resumeCurrentBundle()" style="display:none;">↺ Resume</button>
              <button class="aq-btn aq-btn-sm"            id="btnAutoRun" onclick="autoRunSteps()">⚡ Auto</button>
              <button class="aq-btn aq-btn-sm"            id="btnPin"    onclick="pinCurrentBundle()">☆</button>
              <button class="aq-btn aq-btn-sm aq-btn-danger" onclick="deleteCurrentBundle()">⌫</button>
            </div>
          </div>
          <div class="aq-stats-row">
            <div class="aq-stat"><div class="aq-stat-val c-accent"  id="statSteps">—</div><div class="aq-stat-lbl">Steps</div></div>
            <div class="aq-stat"><div class="aq-stat-val c-green"   id="statDone">—</div><div class="aq-stat-lbl">Done</div></div>
            <div class="aq-stat"><div class="aq-stat-val"            id="statPct">—</div><div class="aq-stat-lbl">Progress</div></div>
            <div class="aq-stat"><div class="aq-stat-val c-amber"   id="statStatus">—</div><div class="aq-stat-lbl">Status</div></div>
            <div class="aq-stat"><div class="aq-stat-val c-purple"  id="statConfidence">—</div><div class="aq-stat-lbl">Confidence</div></div>
          </div>
          <div class="aq-progress-track">
            <div class="aq-progress-fill" id="mainProgressFill" style="width:0%"></div>
            <div class="aq-progress-glow" id="mainProgressGlow" style="left:0%"></div>
          </div>
        </div>
        <div class="aq-exec-content">
          <div class="aq-steps-panel">
            <div class="aq-timeline" id="execTimeline"></div>
            <div class="aq-steps-scroll" id="execSteps"></div>
          </div>
          <div class="aq-right-panel" id="aqRightPanel">
            <div class="aq-right-tabs">
              <button class="aq-right-tab active" data-tab="outputs"  onclick="switchRightTab('outputs',this)">Outputs</button>
              <button class="aq-right-tab"         data-tab="memory"   onclick="switchRightTab('memory',this)">Memory</button>
              <button class="aq-right-tab"         data-tab="insights" onclick="switchRightTab('insights',this)">Insights</button>
            </div>
            <div class="aq-right-body">
              <div class="aq-right-section active" id="rtab-outputs">
                <div id="outputFeed"><div class="aq-empty">Run a step to see outputs.</div></div>
              </div>
              <div class="aq-right-section" id="rtab-memory">
                <div class="aq-mem-hdr">Bundle Memory <span id="memBundleCount">0 keys</span></div>
                <div id="memBundleEntries"></div>
                <div class="aq-mem-hdr" style="margin-top:14px;">Context <span id="memWsCount">0 keys</span></div>
                <div id="memWsEntries"></div>
              </div>
              <div class="aq-right-section" id="rtab-insights">
                <div id="insightList"><div class="aq-empty">Insights appear after steps run.</div></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ─── WELCOME ─── -->
      <div class="aq-welcome" id="wsWelcome">
        <div class="aq-welcome-glyph">⚡</div>
        <h2>Aquiplex Workspace</h2>
        <p>Generate a project with AI, or select a bundle to monitor execution.</p>
        <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;">
          <button class="aq-btn aq-btn-run" onclick="focusPrompt()">⚡ Generate Project</button>
          <button class="aq-btn" onclick="switchLeftTab('bundles')">📦 View Bundles</button>
        </div>
        <div class="aq-welcome-hint">Press ⌘K for commands</div>
      </div>

      <!-- ─── LOADING ─── -->
      <div id="wsLoading" style="display:none;" class="aq-welcome">
        <div style="display:flex;flex-direction:column;gap:10px;width:100%;max-width:300px;">
          <div class="aq-skeleton" style="height:16px;width:55%;"></div>
          <div class="aq-skeleton" style="height:11px;width:75%;"></div>
          <div class="aq-skeleton" style="height:56px;margin-top:10px;"></div>
          <div class="aq-skeleton" style="height:56px;"></div>
        </div>
      </div>

      <!-- ─── ERROR ─── -->
      <div id="wsError" style="display:none;" class="aq-welcome">
        <div style="font-size:1.4rem;opacity:0.5;">⚠</div>
        <div id="wsErrorMsg">Something went wrong.</div>
        <button class="aq-btn" onclick="retryLoad()" style="margin-top:12px;">↺ Retry</button>
      </div>

    </div><!-- /aq-main -->
  </div><!-- /aq-body -->
</div><!-- /aq-workspace -->

<script>
"use strict";

/* ═══════════════════════════════════════════════════════
   GLOBAL STATE
═══════════════════════════════════════════════════════ */
const STATE = {
  bundle:       null,
  wsMemory:     {},
  pinnedIds:    [],
  selectedStep: null,
  openSteps:    new Set(),
  loading:      false,
  lastBundleId: null,
  stepRunning:  new Set(),
  allBundles:   [],
  // project state
  projectId:    null,
  projectFiles: [],
  activeFile:   null,
  dirtyFiles:   new Set(),
  busy:         false,
};

const _ejsBundles = JSON.parse(decodeURIComponent("<%- encodeURIComponent(JSON.stringify(bundles || [])) %>"));
STATE.allBundles = _ejsBundles.slice();

/* ─── LOADING BAR ─── */
function showLoading()  { document.getElementById("aqLoadingBar").classList.add("visible");    STATE.loading = true; }
function hideLoading()  { document.getElementById("aqLoadingBar").classList.remove("visible"); STATE.loading = false; }

/* ─── VIEW HELPERS ─── */
function showView(id) {
  ["wsWelcome","wsLoading","wsExec","wsError","wsProjectView"].forEach(v => {
    const el = document.getElementById(v);
    if (el) el.style.display = (v === id) ? (v === "wsProjectView" ? "flex" : "flex") : "none";
  });
}
function retryLoad() { if (STATE.lastBundleId) { const b = STATE.allBundles.find(x=>String(x._id)===String(STATE.lastBundleId)); if(b) selectBundle(b); } }

/* ─── CONFIRM ─── */
let _confirmResolve = null;
function showConfirm(title, msg, okLabel = "Confirm") {
  return new Promise(resolve => {
    _confirmResolve = resolve;
    document.getElementById("aqConfirmTitle").textContent = title;
    document.getElementById("aqConfirmMsg").textContent   = msg;
    document.getElementById("aqConfirmOk").textContent    = okLabel;
    document.getElementById("aqConfirm").classList.add("open");
  });
}
function resolveConfirm(val) {
  document.getElementById("aqConfirm").classList.remove("open");
  if (_confirmResolve) { _confirmResolve(val); _confirmResolve = null; }
}

/* ─── RUN MODAL ─── */
function openRunModal(title) {
  document.getElementById("runModalTitle").textContent       = title || "Running…";
  document.getElementById("runModalSpinner").style.display   = "flex";
  document.getElementById("runModalOutput").style.display    = "none";
  document.getElementById("runModalFooter").style.display    = "none";
  document.getElementById("runModalOutputContent").innerHTML = "";
  document.getElementById("aqRunModal").classList.add("open");
}
function showRunModalOutput(content) {
  document.getElementById("runModalSpinner").style.display   = "none";
  document.getElementById("runModalOutput").style.display    = "block";
  document.getElementById("runModalFooter").style.display    = "flex";
  document.getElementById("runModalOutputContent").innerHTML = formatOutput(content);
}
function closeRunModal() { document.getElementById("aqRunModal").classList.remove("open"); }

/* ─── SIDEBAR ─── */
function openSidebar()  {
  document.getElementById("aqSidebar").classList.add("open");
  document.getElementById("sidebarCloseBtn").style.display = "";
}
function closeSidebar() {
  document.getElementById("aqSidebar").classList.remove("open");
  document.getElementById("sidebarCloseBtn").style.display = "none";
